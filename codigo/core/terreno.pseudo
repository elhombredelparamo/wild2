# =============================================================================
# ENUMS: TIPOS DE TERRENO Y RECURSOS (Mejorados)
# =============================================================================
class TipoTerreno:
    static AGUA_PROFUNDA = 0      # -100 a -80 metros
    static AGUA_SOMERA = 1        # -80 a -50 metros
    static AGUA_POCO_PROFUND = 2     # -50 a -20 metros
    static AGUA_POCO_PROFUND = 3     # -20 a 0 metros
    static ARENA = 4               # 0 a 5 metros
    static TIERRA_BAJA = 5           # 5 a 50 metros
    static COLINA = 6               # 50 a 200 metros
    static MONTAÑA_BAJA = 7           # 200 a 500 metros
    static MONTAÑA_MEDIA = 8           # 500 a 800 metros
    static MONTAÑA_ALTA = 9           # 800 a 1000 metros
    
    static function ObtenerNombre(tipo: int): string
        try:
            switch tipo:
                case AGUA_PROFUNDA: return "Agua Profunda"
                case AGUA_SOMERA: return "Agua Somera"
                case AGUA_POCO_PROFUND: return "Agua Poco Profunda"
                case ARENA: return "Arena"
                case TIERRA_BAJA: return "Tierra Baja"
                case COLINA: return "Colina"
                case MONTAÑA_BAJA: return "Montaña Baja"
                case MONTAÑA_MEDIA: return "Montaña Media"
                case MONTAÑA_ALTA: return "Montaña Alta"
                default: return "Desconocido"
        catch error as Exception:
            Logger.LogError("TipoTerreno: Error obteniendo nombre: " + error.Message)
            return "Desconocido"
    
    static function EsAcuatico(tipo: int): bool
        try:
            return tipo >= AGUA_PROFUNDA and tipo <= AGUA_POCO_PROFUND
        catch error as Exception:
            Logger.LogError("TipoTerreno: Error verificando si es acuático: " + error.Message)
            return false
    
    static function EsTerreno(tipo: int): bool
        try:
            return tipo >= ARENA and tipo <= MONTAÑA_ALTA
        catch error as Exception:
            Logger.LogError("TipoTerreno: Error verificando si es terreno: " + error.Message)
            return false
    
    static function EsMontaña(tipo: int): bool
        try:
            return tipo >= MONTAÑA_BAJA and tipo <= MONTAÑA_ALTA
        catch error as Exception:
            Logger.LogError("TipoTerreno: Error verificando si es montaña: " + error.Message)
            return false

class TipoRecurso:
    static HIERRO = 0
    static COBRE = 1
    static ORO = 2
    static PLATA = 3
    static PIEDRA = 4
    static ARCILLA = 5
    static CONCHA = 6
    
    static function ObtenerNombre(tipo: int): string
        try:
            switch tipo:
                case HIERRO: return "Hierro"
                case COBRE: return "Cobre"
                case ORO: return "Oro"
                case PLATA: return "Plata"
                case PIEDRA: return "Piedra"
                case ARCILLA: return "Arcilla"
                case CONCHA: return "Concha"
                default: return "Desconocido"
        catch error as Exception:
            Logger.LogError("TipoRecurso: Error obteniendo nombre: " + error.Message)
            return "Desconocido"
    
    static function EsMineral(tipo: int): bool
        try:
            return tipo >= HIERRO and tipo <= PLATA
        catch error as Exception:
            Logger.LogError("TipoRecurso: Error verificando si es mineral: " + error.Message)
            return false
    
    static function EsMaterial(tipo: int): bool
        try:
            return tipo >= PIEDRA and tipo <= ARCILLA
        catch error as Exception:
            Logger.LogError("TipoRecurso: Error verificando si es material: " + error.Message)
            return false

# =============================================================================
# CLASE: DatosChunk (Mejorada)
# =============================================================================
class DatosChunk:
    altitudes: float[10, 10]  # 10x10 = 100 alturas
    tipo_terreno: int[10, 10]
    vegetacion: List<ElementoVegetacion>
    recursos: List<ElementoRecurso>
    modificado: bool = false
    seed_mundo: int
    
    # Sistema de colisiones 3D
    datos_colision: ConcavePolygonShape3D
    cuerpo_colision: StaticBody3D
    
    function Constructor(seed: int = 0):
        try:
            seed_mundo = seed
            altitudes = new float[10, 10]
            tipo_terreno = new int[10, 10]
            vegetacion = new List()
            recursos = new List()
            modificado = false
            datos_colision = null
            cuerpo_colision = null
            
            Logger.LogDebug("DatosChunk: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("DatosChunk: Error en constructor: " + error.Message)
    
    function GenerarColisiones():
        try:
            # Generar ConcavePolygonShape3D desde alturas
            datos_colision = new ConcavePolygonShape3D()
            vertices = GenerarVerticesDesdeAlturas()
            datos_colision.SetVertices(vertices)
            
            # Crear StaticBody3D para el chunk
            cuerpo_colision = new StaticBody3D()
            cuerpo_colision.ShapeOwnerAddShape(datos_colision)
            
            Logger.LogDebug("DatosChunk: Colisiones generadas")
        catch error as Exception:
            Logger.LogError("DatosChunk: Error generando colisiones: " + error.Message)
    
    function GenerarVerticesDesdeAlturas(): List<Vector3>
        try:
            vertices = new List<Vector3>()
            
            # Generar triángulos para cada cuadrado 2x2 de alturas
            for x in range(0, 9):
                for z in range(0, 9):
                    # Obtener 4 vértices del cuadrado
                    v1 = Vector3(x, altitudes[x, z], z)
                    v2 = Vector3(x + 1, altitudes[x + 1, z], z)
                    v3 = Vector3(x + 1, altitudes[x + 1, z + 1], z + 1)
                    v4 = Vector3(x, altitudes[x, z + 1], z + 1)
                    
                    # Validar alturas (rango -100 a 1000)
                    if v1.y < -100 or v1.y > 1000: v1.y = clamp(v1.y, -100, 1000)
                    if v2.y < -100 or v2.y > 1000: v2.y = clamp(v2.y, -100, 1000)
                    if v3.y < -100 or v3.y > 1000: v3.y = clamp(v3.y, -100, 1000)
                    if v4.y < -100 or v4.y > 1000: v4.y = clamp(v4.y, -100, 1000)
                    
                    # Agregar dos triángulos para el cuadrado
                    vertices.Add(v1)
                    vertices.Add(v2)
                    vertices.Add(v3)
                    
                    vertices.Add(v1)
                    vertices.Add(v3)
                    vertices.Add(v4)
            
            return vertices
        catch error as Exception:
            Logger.LogError("DatosChunk: Error generando vertices: " + error.Message)
            return new List<Vector3>()
    
    function ActualizarColisiones():
        try:
            # Regenerar colisiones si el terreno cambió
            if modificado and cuerpo_colision != null:
                GenerarColisiones()
                modificado = false
                Logger.LogDebug("DatosChunk: Colisiones actualizadas")
        catch error as Exception:
            Logger.LogError("DatosChunk: Error actualizando colisiones: " + error.Message)
    
    function Modificar():
        try:
            modificado = true
            Logger.LogDebug("DatosChunk: Modificado")
        catch error as Exception:
            Logger.LogError("DatosChunk: Error modificando: " + error.Message)
    
    function Liberar():
        try:
            # Liberar colisiones
            if cuerpo_colision != null:
                cuerpo_colision.Free()
                cuerpo_colision = null
            
            if datos_colision != null:
                datos_colision.Free()
                datos_colision = null
            
            # Liberar listas
            if vegetacion != null:
                vegetacion.Clear()
            
            if recursos != null:
                recursos.Clear()
            
            Logger.LogDebug("DatosChunk: Liberado")
        catch error as Exception:
            Logger.LogError("DatosChunk: Error liberando: " + error.Message)
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            Logger.LogInfo("DatosChunk: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("DatosChunk: Error configurando seed: " + error.Message)
    
    function GetSeed(): int
        try:
            return seed_mundo
        catch error as Exception:
            Logger.LogError("DatosChunk: Error obteniendo seed: " + error.Message)
            return 0
    
    function EstaModificado(): bool
        try:
            return modificado
        catch error as Exception:
            Logger.LogError("DatosChunk: Error verificando si está modificado: " + error.Message)
            return false
    
    function ObtenerAlturaPromedio(): float
        try:
            suma = 0.0
            for x in range(0, 10):
                for z in range(0, 10):
                    suma += altitudes[x, z]
            return suma / 100.0  # 10x10 = 100 alturas
        catch error as Exception:
            Logger.LogError("DatosChunk: Error obteniendo altura promedio: " + error.Message)
            return 0.0
    
    function ObtenerTipoDominante(): int
        try:
            conteo_tipos = new Dictionary()
            
            for x in range(0, 10):
                for z in range(0, 10):
                    tipo = tipo_terreno[x, z]
                    if conteo_tipos.ContainsKey(tipo):
                        conteo_tipos[tipo] += 1
                    else:
                        conteo_tipos[tipo] = 1
            
            # Encontrar el tipo más común
            tipo_dominante = 0
            max_conteo = 0
            
            for tipo, conteo in conteo_tipos:
                if conteo > max_conteo:
                    max_conteo = conteo
                    tipo_dominante = tipo
            
            return tipo_dominante
        catch error as Exception:
            Logger.LogError("DatosChunk: Error obteniendo tipo dominante: " + error.Message)
            return TipoTerreno.TIERRA_BAJA  # Fallback
    
    function ObtenerEstadisticas(): Dictionary<string, object>
        try:
            stats = new Dictionary()
            stats["altura_promedio"] = ObtenerAlturaPromedio()
            stats["tipo_dominante"] = ObtenerTipoDominante()
            stats["vegetacion_count"] = vegetacion.length()
            stats["recursos_count"] = recursos.length()
            stats["modificado"] = modificado
            stats["seed"] = seed_mundo
            return stats
        catch error as Exception:
            Logger.LogError("DatosChunk: Error obteniendo estadísticas: " + error.Message)
            return new Dictionary()

# =============================================================================
# CLASE: SistemaColisionesTerreno (Mejorada)
# =============================================================================
class SistemaColisionesTerreno:
    seed_mundo: int
    chunks_con_colision: Dictionary<string, StaticBody3D>
    
    function Constructor(seed: int = 0):
        try:
            seed_mundo = seed
            chunks_con_colision = new Dictionary()
            Logger.LogInfo("SistemaColisionesTerreno: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error en constructor: " + error.Message)
    
    function GenerarColisionesChunk(datos: DatosChunk, coord: CoordenadaGlobal): DatosChunk
        try:
            # Validar datos y coordenada
            if datos == null or coord == null:
                Logger.LogError("SistemaColisionesTerreno: Datos o coordenada nulos")
                return datos
            
            # Generar colisiones 3D
            datos.GenerarColisiones()
            
            # Posicionar cuerpo en coordenadas del chunk
            if datos.cuerpo_colision != null:
                datos.cuerpo_colision.Position = Vector3(coord.chunk_x * 10, 0, coord.chunk_z * 10)
                
                # Añadir al mundo 3D
                GetWorld3D().AddChild(datos.cuerpo_colision)
                
                # Registrar en el sistema
                clave = coord.chunk_x.ToString() + "_" + coord.chunk_z.ToString()
                chunks_con_colision[clave] = datos.cuerpo_colision
            
            Logger.LogDebug("SistemaColisionesTerreno: Colisiones generadas para " + coord.ToString())
            return datos
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error generando colisiones chunk: " + error.Message)
            return datos
    
    function RemoverColisionChunk(cuerpo: StaticBody3D):
        try:
            if cuerpo != null:
                # Remover del mundo 3D
                GetWorld3D().RemoveChild(cuerpo)
                
                # Liberar memoria
                cuerpo.Free()
                
                # Eliminar del registro
                clave_a_eliminar = ""
                for clave, cuerpo_registrado in chunks_con_colision:
                    if cuerpo_registrado == cuerpo:
                        clave_a_eliminar = clave
                        break
                
                if clave_a_eliminar != "":
                    chunks_con_colision.Remove(clave_a_eliminar)
                
                Logger.LogDebug("SistemaColisionesTerreno: Colisiones removidas")
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error removiendo colisiones chunk: " + error.Message)
    
    function ActualizarColisionChunk(datos: DatosChunk, coord: CoordenadaGlobal):
        try:
            # Validar datos y coordenada
            if datos == null or coord == null:
                Logger.LogError("SistemaColisionesTerreno: Datos o coordenada nulos en actualización")
                return
            
            # Actualizar colisiones si el terreno cambió
            if datos.EstaModificado():
                # Remover colisiones antiguas
                clave = coord.chunk_x.ToString() + "_" + coord.chunk_z.ToString()
                if chunks_con_colision.ContainsKey(clave):
                    cuerpo_antiguo = chunks_con_colision[clave]
                    RemoverColisionChunk(cuerpo_antiguo)
                
                # Generar nuevas colisiones
                GenerarColisionesChunk(datos, coord)
                
                Logger.LogDebug("SistemaColisionesTerreno: Colisiones actualizadas para " + coord.ToString())
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error actualizando colisiones chunk: " + error.Message)
    
    function ObtenerColisionChunk(coord: CoordenadaGlobal): StaticBody3D
        try:
            if coord == null:
                Logger.LogError("SistemaColisionesTerreno: Coordenada nula en ObtenerColisionChunk")
                return null
            
            clave = coord.chunk_x.ToString() + "_" + coord.chunk_z.ToString()
            if chunks_con_colision.ContainsKey(clave):
                return chunks_con_colision[clave]
            else:
                return null
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error obteniendo colision chunk: " + error.Message)
            return null
    
    function ExisteColisionChunk(coord: CoordenadaGlobal): bool
        try:
            if coord == null:
                return false
            
            clave = coord.chunk_x.ToString() + "_" + coord.chunk_z.ToString()
            return chunks_con_colision.ContainsKey(clave)
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error verificando si existe colisión: " + error.Message)
            return false
    
    function LimpiarTodasColisiones():
        try:
            # Remover todas las colisiones del mundo
            for clave, cuerpo in chunks_con_colision:
                if cuerpo != null:
                    GetWorld3D().RemoveChild(cuerpo)
                    cuerpo.Free()
            
            # Limpiar registro
            chunks_con_colision.Clear()
            
            Logger.LogInfo("SistemaColisionesTerreno: Todas las colisiones limpiadas")
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error limpiando colisiones: " + error.Message)
    
    function ObtenerEstadisticas(): Dictionary<string, object>
        try:
            stats = new Dictionary()
            stats["chunks_con_colision"] = chunks_con_colision.length()
            stats["seed_mundo"] = seed_mundo
            return stats
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error obteniendo estadísticas: " + error.Message)
            return new Dictionary()
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            Logger.LogInfo("SistemaColisionesTerreno: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error configurando seed: " + error.Message)
    
    function GetSeed(): int
        try:
            return seed_mundo
        catch error as Exception:
            Logger.LogError("SistemaColisionesTerreno: Error obteniendo seed: " + error.Message)
            return 0

# =============================================================================
# FUNCIONES GLOBALES DE ACCESO RÁPIDO
# =============================================================================
# FUNCIONES DE ACCESO (DEPRECATED)
# =============================================================================
# NOTA: Estas funciones están obsoletas y violan el principio de evitar referencias circulares
# Se deben eliminar y reemplazar por inyección de dependencias desde GameManager
# =============================================================================

function GetSistemaTerreno(): SistemaTerreno
    return ManejoErrores.EjecutarConManejo(() => {
        if GameManager.instance == null:
            Logger.LogError("GetSistemaTerreno: GameManager no inicializado")
            return EstadoSeguroTerreno.ObtenerValorPorDefecto("chunk_nulo")
        return GameManager.instance.sistema_terreno
    }, "GetSistemaTerreno", false)

function InicializarTerreno(seed: int = 0): SistemaTerreno
    # NOTA: Esta función está obsoleta y viola el principio de evitar referencias circulares
    # Se debe usar GameManager.instance.sistema_terreno.Inicializar()
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = new SistemaTerreno()
        sistema.Inicializar()
        if sistema != null:
            Logger.LogInfo("Terreno: Sistema inicializado correctamente")
        return sistema
    }, "InicializarTerreno", false)

function ActualizarTerreno(delta_time):
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaTerreno()
        if sistema != null:
            sistema.ActualizarChunks(delta_time)
        else:
            Logger.LogError("Terreno: No se pudo actualizar - SistemaTerreno no disponible")
        return true
    }, "ActualizarTerreno", false)

function ObtenerEstadisticasTerreno(): Dictionary<string, object>
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaTerreno()
        if sistema != null:
            return sistema.ObtenerEstadisticas()
        else:
            return EstadoSeguroTerreno.ObtenerValorPorDefecto("estadisticas_vacias")
    }, "ObtenerEstadisticasTerreno", false)

# =============================================================================
# FUNCIONES DE UTILIDAD
# =============================================================================
function clamp(valor: float, minimo: float, maximo: float): float
    return ManejoErrores.EjecutarConManejo(() => {
        if valor < minimo:
            return minimo
        elif valor > maximo:
            return maximo
        else:
            return valor
    }, "clamp", false)

function floor(valor: float): int
    return ManejoErrores.EjecutarConManejo(() => {
        return int(valor)
    }, "floor", false)

# =============================================================================
# CLASES AUXILIARES DE RUIDO
# =============================================================================
class NoiseGenerator:
    seed: int
    
    function Constructor(seed: int = 0):
        try:
            self.seed = seed
            Logger.LogDebug("NoiseGenerator: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("NoiseGenerator: Error en constructor: " + error.Message)
    
    function Perlin(x: float, y: float, z: float): float
        try:
            # Simulación de ruido Perlin con seed
            # (Aquí iría la implementación real)
            return sin(x + seed) * cos(y + seed) * cos(z + seed)
        catch error as Exception:
            Logger.LogError("NoiseGenerator: Error generando ruido Perlin: " + error.Message)
            return 0.0
    
    function SetSeed(seed: int):
        try:
            self.seed = seed
            Logger.LogDebug("NoiseGenerator: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("NoiseGenerator: Error configurando seed: " + error.Message)
    
    function GetSeed(): int
        try:
            return seed
        catch error as Exception:
            Logger.LogError("NoiseGenerator: Error obteniendo seed: " + error.Message)
            return 0
