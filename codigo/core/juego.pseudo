# Descripción: Orquestación principal del juego Wild v2.0
# Autor: Cascade
# Fecha: 2026-03-11

# =============================================================================
# CLASE PRINCIPAL: GameManager (Singleton)
# =============================================================================
class GameManager:
    # Instancia única manejada externamente
    static instance: GameManager = null
    
    # Propiedades principales
    estado_juego: EstadoJuego
    sistema_terreno: SistemaTerreno
    sistema_biomas: SistemaBiomas
    sistema_calidad: SistemaCalidad
    sistema_red: SistemaRed
    sistema_jugador: SistemaJugador
    sistema_render: SistemaRender
    sistema_ui: SistemaUI
    sistema_persistencia: SistemaPersistenciaServidor
    sistema_conexion_mundos: SistemaConexionServidor
    sistema_colisiones: SistemaColisionesTerreno
    sistema_habilidades: SistemaHabilidades
    sistema_fisica: SistemaFisicaJugador
    resource_loader: DynamicResourceLoader
    # seed_mundo eliminada - usar SessionData.Instance.seed_mundo
    
    # =============================================================================
    # FUNCIONES PRINCIPALES
    # =============================================================================
    
    # Inicialización del sistema
    static function Inicializar(): GameManager
        return ManejoErrores.EjecutarConManejo(() => {
            if instance == null:
                instance = new GameManager()
                instance._InicializarInterno()
                Logger.LogInfo("GameManager: Sistema inicializado")
            return instance
        }, "GameManager.Inicializar", true)
    
    # Inicialización interna
    function _InicializarInterno():
        return ManejoErrores.EjecutarConManejo(() => {
            # Generar seed para el mundo si no existe
            if SessionData.Instance.seed_mundo == 0:
                SessionData.Instance.seed_mundo = GenerarSeedAleatoria()
                Logger.LogInfo("GameManager: Seed generada: " + SessionData.Instance.seed_mundo.ToString())
            
            # Establecer datos en SessionData
            SessionData.Instance.nombre_mundo = "Mundo_" + str(SessionData.Instance.seed_mundo)
            SessionData.Instance.ruta_mundo = "worlds/" + SessionData.Instance.nombre_mundo
            
            # Inicializar sistemas con inyección de dependencias
            InicializarLogger()
            InicializarConfiguracion()
            InicializarSistemaPersistencia()
            InicializarSistemaConexionMundos()
            InicializarSistemaCalidad()
            InicializarSistemaCoordenadas()
            InicializarResourceLoader()
            InicializarSistemaFisica()
            InicializarSistemaColisiones()
            InicializarSistemaTerreno()  # Inyecta SistemaBiomas
            # SistemaBiomas ya está inicializado dentro de SistemaTerreno
            InicializarSistemaHabilidades()
            InicializarSistemaRender()
            InicializarSistemaUI()
            InicializarSistemaJugador()
            InicializarSistemaRed()
            
            # Establecer estado inicial
            estado_juego = EstadoJuego.MENU_PRINCIPAL
            
            Logger.LogInfo("GameManager: Todos los sistemas inicializados")
            return true
        }, "GameManager._InicializarInterno", true)
    
    # Bucle principal del juego
    function ActualizarJuego(delta_time):
        return ManejoErrores.EjecutarConManejo(() => {
            # Nota: El juego siempre se actualiza, incluso con menú de pausa abierto
            # El servidor local nunca se detiene para mantener consistencia con multijugador
            
            # Actualizar sistemas en orden
            sistema_red.ProcesarMensajes()
            sistema_persistencia.ProcesarTransacciones()
            sistema_jugador.ActualizarJugadores(delta_time)
            sistema_fisica.ActualizarFisica(delta_time)
            sistema_terreno.ActualizarChunks(delta_time)
            sistema_colisiones.ActualizarColisiones(delta_time)
            sistema_render.ActualizarEscena(delta_time)
            sistema_ui.ActualizarInterfaz(delta_time)
            sistema_habilidades.ActualizarHabilidades(delta_time)
            
            # Persistencia continua - guardar cambios automáticamente
            # El servidor guarda datos continuamente, sin importar el estado de la UI
            ActualizarPersistencia(delta_time)
            return true
        }, "GameManager.ActualizarJuego", false)
    
    # Cierre del juego
    function CerrarJuego():
        return ManejoErrores.EjecutarConManejo(() => {
            # Desconectar del mundo si está conectado
            if sistema_conexion_mundos.EstaConectado():
                sistema_conexion_mundos.DesconectarMundo()
            
            # Guardar estado final
            GuardarEstadoFinal()
            
            # Liberar recursos
            sistema_render.LiberarRecursos()
            sistema_red.Desconectar()
            resource_loader.LiberarTodo()
            
            Logger.LogInfo("GameManager: Juego cerrado correctamente")
            exit(0)
        }, "GameManager.CerrarJuego", false)

# =============================================================================
# CLASE: EstadoSeguroJuego
# =============================================================================
class EstadoSeguroJuego:
    static valores_por_defecto: Dictionary<string, object>
    
    static function Inicializar():
        valores_por_defecto = new Dictionary()
        # Valores seguros para cada sistema
        valores_por_defecto["estado_juego"] = EstadoJuego.MENU_PRINCIPAL
        valores_por_defecto["seed_mundo"] = 123456789
        valores_por_defecto["nombre_mundo"] = "Mundo_Default"
        valores_por_defecto["ruta_mundo"] = "worlds/Mundo_Default"
        valores_por_defecto["nombre_jugador"] = "Jugador"
        valores_por_defecto["posicion_jugador"] = Vector3.ZERO
        valores_por_defecto["calidad_actual"] = NivelCalidad.MEDIUM
        valores_por_defecto["limite_memoria"] = 500  # MB
        valores_por_defecto["distancia_carga"] = 5
        valores_por_defecto["resolucion_chunks"] = 10
        valores_por_defecto["lod_maximo"] = 3
    
    static function ObtenerValorPorDefecto(contexto: string): object
        if valores_por_defecto.ContainsKey(contexto):
            return valores_por_defecto[contexto]
        else:
            Logger.LogWarning("EstadoSeguroJuego: Sin valor por defecto para: " + contexto)
            return EstadoJuego.MENU_PRINCIPAL  # Fallback seguro

# =============================================================================
# CLASE: EstadoJuego
# =============================================================================
class EstadoJuego:
    static MENU_PRINCIPAL = 0
    static CONECTANDO = 1
    static JUGANDO = 2
    static CARGANDO = 3
    static ERROR = 4
    # Nota: No existe estado PAUSADO - el juego nunca se detiene completamente

# =============================================================================
# FUNCIONES GLOBALES DE ACCESO (DEPRECATED)
# =============================================================================
# NOTA: Estas funciones están obsoletas y violan el principio de evitar referencias circulares
# Se deben eliminar y reemplazar por inyección de dependencias
# =============================================================================

function GetGameManager(): GameManager
    return ManejoErrores.EjecutarConManejo(() => {
        if GameManager.instance == null:
            Logger.LogError("GetGameManager: GameManager no inicializado")
            return EstadoSeguroJuego.ObtenerValorPorDefecto("game_manager")
        return GameManager.instance
    }, "GetGameManager", false)

function GetEstadoActual(): EstadoJuego
    return ManejoErrores.EjecutarConManejo(() => {
        game_manager = GetGameManager()
        if game_manager != null:
            return game_manager.estado_juego
        return EstadoSeguroJuego.ObtenerValorPorDefecto("estado_juego")
    }, "GetEstadoActual", false)

function CambiarEstado(nuevo_estado: EstadoJuego):
    return ManejoErrores.EjecutarConManejo(() => {
        game_manager = GetGameManager()
        if game_manager != null:
            estado_anterior = game_manager.estado_juego
            game_manager.estado_juego = nuevo_estado
            Logger.LogInfo("GameManager: Estado cambiado de " + estado_anterior.ToString() + " a " + nuevo_estado.ToString())
            return true
        else:
            Logger.LogError("CambiarEstado: GameManager no disponible")
            return false
    }, "CambiarEstado", false)

