# =============================================================================
# FUNCIONES DE PERSISTENCIA CONTINUA
# =============================================================================
function ActualizarPersistencia(delta_time):
    return ManejoErrores.EjecutarConManejo(() => {
        # La persistencia se maneja automáticamente a través de transacciones
        # Esta función puede usarse para tareas periódicas de mantenimiento
        
        # Guardar estado del servidor periódicamente
        if sistema_persistencia != null:
            sistema_persistencia.ActualizarMantenimiento(delta_time)
        
        # Actualizar métricas de rendimiento
        if sistema_calidad != null:
            sistema_calidad.Actualizar(delta_time)
        
        # Procesar cola de transacciones pendientes
        if sistema_persistencia != null:
            sistema_persistencia.ProcesarColaTransacciones()
        return true
    }, "ActualizarPersistencia", false)

function ConectarMundo(nombre_mundo: string, nombre_jugador: string): bool
    return ManejoErrores.EjecutarConManejo(() => {
        resultado = sistema_conexion_mundos.ConectarMundo(nombre_mundo, nombre_jugador)
        
        if resultado.exito:
            CambiarEstado(EstadoJuego.JUGANDO)
            sistema_ui.CambiarEstado(EstadoUI.JUGANDO)
            Logger.LogInfo("GameManager: Conectado al mundo " + nombre_mundo + " como " + nombre_jugador)
            return true
        else:
            Logger.LogError("GameManager: Error conectando al mundo " + nombre_mundo + ": " + resultado.error)
            return EstadoSeguroJuego.ObtenerValorPorDefecto("conexion_fallida")
    }, "ConectarMundo", false)

function CrearMundo(nombre_mundo: string, configuracion: ConfiguracionMundo): bool
    return ManejoErrores.EjecutarConManejo(() => {
        exito = sistema_persistencia.CrearMundo(nombre_mundo, configuracion)
        
        if exito:
            Logger.LogInfo("GameManager: Mundo creado exitosamente: " + nombre_mundo)
        else:
            Logger.LogError("GameManager: Error creando mundo: " + nombre_mundo)
        
        return exito
    }, "CrearMundo", false)

# =============================================================================
# FUNCIONES AUXILIARES
# =============================================================================
function GenerarSeedAleatoria(): int
    return ManejoErrores.EjecutarConManejo(() => {
        # Generar seed aleatoria de 32 bits
        random = new Random()
        seed = random.Next(0, 2147483647)  # 2^31 - 1
        Logger.LogInfo("GameManager: Seed aleatoria generada: " + seed.ToString())
        return seed
    }, "GenerarSeedAleatoria", false)

function GuardarEstadoFinal():
    return ManejoErrores.EjecutarConManejo(() => {
        # Guardar estado final del juego antes de cerrar
        estado_final = {
            "timestamp": DateTime.Now().ToString("O"),
            "estado_juego": GetEstadoActual().ToString(),
            "jugador_posicion": sistema_jugador.GetJugadorLocal().posicion,
            "mundo_actual": sistema_conexion_mundos.GetMundoActual(),
            "seed_mundo": SessionData.Instance.seed_mundo
        }
        
        ruta_estado = "user://final_game_state.json"
        json_str = JsonConvert.SerializeObject(estado_final, Formatting.Indented)
        
        archivo = FileAccess.Open(ruta_estado, FileAccess.ModeFlags.WRITE)
        archivo.StoreString(json_str)
        archivo.Close()
        
        Logger.LogInfo("GameManager: Estado final guardado")
        return true
    }, "GuardarEstadoFinal", false)

