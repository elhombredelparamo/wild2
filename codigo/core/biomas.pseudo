        try:
            # Aguas profundas -50 a -20 metros
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.04, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] = -35 + ruido * 15  # -50 a -20 metros
            Logger.LogInfo("BiomaAguaProfunda: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaAguaProfunda: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarVegetacion(datos: DatosChunk): DatosChunk
        try:
            # Algas marinas en aguas profundas
            for x in 0..9:
                for z in 0..9:
                    if Random() < 0.05:  # 5% probabilidad de algas
                        alga = new AlgaMarina(x, z)
                        if ValidarElementoVegetacion(alga):
                            datos.vegetacion.Add(alga)
                            Logger.LogInfo("BiomaAguaProfunda: Alga marina agregada en (" + x + "," + z + ")")
                        else:
                            Logger.LogWarning("BiomaAguaProfunda: Alga marina inválida omitida en posición (" + x + "," + z + ")")
            Logger.LogInfo("BiomaAguaProfunda: Vegetación agregada")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaAguaProfunda: Error agregando vegetación - " + error.Message)
            return datos

class BiomaCosta extends Bioma:
    function ModificarAlturas(datos: DatosChunk): DatosChunk
        try:
            # Costas -20 a 0 metros
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.06, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] = -10 + ruido * 10  # -20 a 0 metros
            Logger.LogInfo("BiomaCosta: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaCosta: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarVegetacion(datos: DatosChunk): DatosChunk
        try:
            # Hierba costera y algas
            for x in 0..9:
                for z in 0..9:
                    if Random() < 0.2:  # 20% probabilidad
                        if Random() < 0.5:
                            alga = new AlgaMarina(x, z)
                            if ValidarElementoVegetacion(alga):
                                datos.vegetacion.Add(alga)
                                Logger.LogInfo("BiomaCosta: Alga marina agregada en (" + x + "," + z + ")")
                            else:
                                Logger.LogWarning("BiomaCosta: Alga marina inválida omitida en posición (" + x + "," + z + ")")
                        else:
                            hierba = new HierbaCostera(x, z)
                            if ValidarElementoVegetacion(hierba):
                                datos.vegetacion.Add(hierba)
                                Logger.LogInfo("BiomaCosta: Hierba costera agregada en (" + x + "," + z + ")")
                            else:
                                Logger.LogWarning("BiomaCosta: Hierba costera inválida omitida en posición (" + x + "," + z + ")")
            Logger.LogInfo("BiomaCosta: Vegetación agregada")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaCosta: Error agregando vegetación - " + error.Message)
            return datos

