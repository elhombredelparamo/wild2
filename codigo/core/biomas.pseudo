# =============================================================================
# SISTEMA DE BIOMAS
# =============================================================================
# Archivo: biomas.pseudo
# Descripción: Definición y aplicación de biomas en el terreno
# Autor: Cascade
# Fecha: 2026-03-11

# =============================================================================
# CLASE PRINCIPAL: SistemaBiomas
# =============================================================================
class SistemaBiomas:
    # Propiedades principales
    biomas_disponibles: Dictionary<TipoBioma, Bioma>
    generador_biomas: GeneradorBiomas
    mapa_biomas: MapaBiomas
    # seed_mundo eliminada - ahora usa SessionData.Instance.seed_mundo
    
    # =============================================================================
    # FUNCIONES PRINCIPALES
    # =============================================================================
    
    # Inicialización del sistema
    function Inicializar(seed: int = 0):
        try:
            # Establecer seed en SessionData
            SessionData.Instance.seed_mundo = seed
            generador_biomas.ActualizarSeed()
            
            biomas_disponibles = new Dictionary()
            generador_biomas = new GeneradorBiomas()
            mapa_biomas = new MapaBiomas()
            
            # Registrar biomas base
            RegistrarBiomasBase()
            
            Logger.LogInfo("SistemaBiomas: Inicialización completada")
        catch error as Exception:
            Logger.LogError("SistemaBiomas: Error en inicialización - " + error.Message)
    
    # Establecer seed del mundo para generación reproducible
    function EstablecerSeed(seed: int):
        try:
            # Ya no se almacena localmente, se usa SessionData
            SessionData.Instance.seed_mundo = seed
            generador_biomas.ActualizarSeed()
            Logger.LogInfo("SistemaBiomas: Seed de biomas establecida: " + str(seed))
        catch error as Exception:
            Logger.LogError("SistemaBiomas: Error estableciendo seed - " + error.Message)
    
    # Obtener bioma para una coordenada
    function ObtenerBioma(coord: CoordenadaGlobal): Bioma
        try:
            tipo_bioma = generador_biomas.DeterminarTipoBioma(coord)
            
            if biomas_disponibles.ContainsKey(tipo_bioma):
                return biomas_disponibles[tipo_bioma]
            else:
                Logger.LogWarning("Bioma no encontrado: " + tipo_bioma.ToString())
                return biomas_disponibles[TipoBioma.PRADERA]  # Por defecto seguro
        catch error as Exception:
            Logger.LogError("SistemaBiomas: Error obteniendo bioma - " + error.Message)
            return biomas_disponibles[TipoBioma.PRADERA]  # Por defecto seguro
    
    # Modificar chunk según bioma
    function ModificarChunkConBioma(datos_chunk: DatosChunk, coord: CoordenadaGlobal): DatosChunk
        try:
            bioma = ObtenerBioma(coord)
            resultado = bioma.ModificarChunk(datos_chunk)
            Logger.LogInfo("SistemaBiomas: Chunk modificado con bioma")
            return resultado
        catch error as Exception:
            Logger.LogWarning("SistemaBiomas: Error modificando chunk con bioma - " + error.Message)
            return datos_chunk  # Devolver chunk sin modificar
    
    # =============================================================================
    # FUNCIONES AUXILIARES
    # =============================================================================
    
    function RegistrarBiomasBase():
        try:
            # Crear instancias de biomas base
            biomas_disponibles[TipoBioma.BOSQUE] = new BiomaBosque()
            biomas_disponibles[TipoBioma.DESIERTO] = new BiomaDesierto()
            biomas_disponibles[TipoBioma.MONTAÑA] = new BiomaMontaña()
            biomas_disponibles[TipoBioma.OCEANO] = new BiomaOceano()
            biomas_disponibles[TipoBioma.PRADERA] = new BiomaPradera()
            biomas_disponibles[TipoBioma.TUNDRA] = new BiomaTundra()
            biomas_disponibles[TipoBioma.JUNGLA] = new BiomaSelva()
            
            # Nuevos biomas acuáticos para alturas negativas
            biomas_disponibles[TipoBioma.AGUA_PROFUNDA] = new BiomaAguaProfunda()
            biomas_disponibles[TipoBioma.AGUA_SOMERA] = new BiomaAguaSomera()
            biomas_disponibles[TipoBioma.COSTA] = new BiomaCosta()
            biomas_disponibles[TipoBioma.RIO] = new BiomaRio()
            biomas_disponibles[TipoBioma.MARISMA] = new BiomaMarisma()
            biomas_disponibles[TipoBioma.ISLA] = new BiomaIsla()
            
            Logger.LogInfo("SistemaBiomas: Biomas base registrados")
        catch error as Exception:
            Logger.LogError("SistemaBiomas: Error crítico registrando biomas base - " + error.Message)

# =============================================================================
# CLASE BASE: Bioma
# =============================================================================
class Bioma:
    tipo: TipoBioma
    nombre: string
    temperatura_base: float
    humedad_base: float
    altitud_minima: float
    altitud_maxima: float
    
    # Función principal de modificación
    function ModificarChunk(datos_chunk: DatosChunk): DatosChunk
        # Modificar alturas según características del bioma
        datos_chunk = ModificarAlturas(datos_chunk)
        
        # Agregar vegetación característica
        datos_chunk = AgregarVegetacion(datos_chunk)
        
        # Agregar recursos característicos
        datos_chunk = AgregarRecursos(datos_chunk)
        
        # Modificar tipo de terreno
        datos_chunk = ModificarTipoTerreno(datos_chunk)
        
        return datos_chunk
    
    # Funciones virtuales a implementar por cada bioma
    virtual function ModificarAlturas(datos: DatosChunk): DatosChunk
    virtual function AgregarVegetacion(datos: DatosChunk): DatosChunk
    virtual function AgregarRecursos(datos: DatosChunk): DatosChunk
    virtual function ModificarTipoTerreno(datos: DatosChunk): DatosChunk

# =============================================================================
# BIOMAS ESPECÍFICOS
# =============================================================================

class BiomaBosque extends Bioma:
    function ModificarAlturas(datos: DatosChunk): DatosChunk
        try:
            # Bosques tienen variación moderada de alturas
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.1, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] += ruido * 2.0
            Logger.LogInfo("BiomaBosque: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaBosque: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarVegetacion(datos: DatosChunk): DatosChunk
        try:
            # Agregar árboles principalmente
            for x in 0..9:
                for z in 0..9:
                    if Random() < 0.3:  # 30% probabilidad de árbol
                        arbol = new Arbol(x, z)
                        if ValidarElementoVegetacion(arbol):
                            datos.vegetacion.Add(arbol)
                            Logger.LogInfo("BiomaBosque: Árbol agregado en (" + x + "," + z + ")")
                        else:
                            Logger.LogWarning("BiomaBosque: Árbol inválido omitido en posición (" + x + "," + z + ")")
            Logger.LogInfo("BiomaBosque: Vegetación agregada")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaBosque: Error agregando vegetación - " + error.Message)
            return datos

class BiomaDesierto extends Bioma:
    function ModificarAlturas(datos: DatosChunk): DatosChunk
        try:
            # Desiertos son más planos con dunas
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.05, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] += ruido * 1.0
            Logger.LogInfo("BiomaDesierto: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaDesierto: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarVegetacion(datos: DatosChunk): DatosChunk
        try:
            # Poca vegetación, principalmente cactus
            for x in 0..9:
                for z in 0..9:
                    if Random() < 0.05:  # 5% probabilidad de cactus
                        cactus = new Cactus(x, z)
                        if ValidarElementoVegetacion(cactus):
                            datos.vegetacion.Add(cactus)
                            Logger.LogInfo("BiomaDesierto: Cactus agregado en (" + x + "," + z + ")")
                        else:
                            Logger.LogWarning("BiomaDesierto: Cactus inválido omitido en posición (" + x + "," + z + ")")
            Logger.LogInfo("BiomaDesierto: Vegetación agregada")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaDesierto: Error agregando vegetación - " + error.Message)
            return datos

class BiomaMontaña extends Bioma:
    function ModificarAlturas(datos: DatosChunk): DatosChunk
        try:
            # Montañas tienen gran variación de alturas
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.2, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] += ruido * 5.0
            Logger.LogInfo("BiomaMontaña: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaMontaña: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarRecursos(datos: DatosChunk): DatosChunk
        try:
            # Minerales en montañas
            for x in 0..9:
                for z in 0..9:
                    if Random() < 0.1:  # 10% probabilidad de mineral
                        mineral = new Mineral(x, z)
                        if ValidarElementoRecurso(mineral):
                            datos.recursos.Add(mineral)
                            Logger.LogInfo("BiomaMontaña: Mineral agregado en (" + x + "," + z + ")")
                        else:
                            Logger.LogWarning("BiomaMontaña: Mineral inválido omitido en posición (" + x + "," + z + ")")
            Logger.LogInfo("BiomaMontaña: Recursos agregados")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaMontaña: Error agregando recursos - " + error.Message)
            return datos

# =============================================================================
# BIOMAS ACUÁTICOS (Nuevos para alturas negativas)
# =============================================================================

class BiomaOceano extends Bioma:
    function ModificarAlturas(datos: DatosChunk): DatosChunk
        try:
            # Océano profundo - alturas muy bajas
            for x in 0..9:
                for z in 0..9:
                    ruido = GenerarRuidoPerlinConSeed(x, z, 0.03, SessionData.Instance.seed_mundo)
                    datos.altitudes[x, z] = -80 + ruido * 20  # -100 a -60 metros
            Logger.LogInfo("BiomaOceano: Alturas modificadas")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaOceano: Error modificando alturas - " + error.Message)
            return datos
    
    function AgregarVegetacion(datos: DatosChunk): DatosChunk
        try:
            # Sin vegetación en océano profundo
            Logger.LogInfo("BiomaOceano: Vegetación procesada (sin vegetación en océano)")
            return datos
        catch error as Exception:
            Logger.LogError("BiomaOceano: Error procesando vegetación - " + error.Message)
            return datos

class BiomaAguaProfunda extends Bioma:
