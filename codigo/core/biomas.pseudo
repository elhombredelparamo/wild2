        catch error as Exception:
            Logger.LogError("BiomaMarisma: Error agregando vegetación - " + error.Message)
            return datos

# =============================================================================
# CLASE: GeneradorBiomas
# =============================================================================
class GeneradorBiomas:
    # seed_mundo eliminada - ahora usa SessionData.Instance.seed_mundo
    
    function ActualizarSeed():
        # Función para notificar cambios de seed si es necesario
        pass
    
    function DeterminarTipoBioma(coord: CoordenadaGlobal): TipoBioma
        try:
            # Usar coordenadas y ruido para determinar bioma
            altitud = ObtenerAltitudBaseConSeed(coord, SessionData.Instance.seed_mundo)
            humedad = ObtenerHumedadBaseConSeed(coord, SessionData.Instance.seed_mundo)
            temperatura = ObtenerTemperaturaBaseConSeed(coord, SessionData.Instance.seed_mundo)
            
            # Lógica de determinación de bioma con nuevo rango de alturas
            if altitud < -20:      # Aguas poco profundas a profundas
                if humedad > 0.8:
                    resultado = TipoBioma.OCEANO
                else:
                    resultado = TipoBioma.RIO
            elif altitud < 0:       # Aguas poco profundas y costas
                if humedad > 0.6:
                    resultado = TipoBioma.MARISMA
                else:
                    resultado = TipoBioma.ISLA
            elif altitud < 50:      # Terrenos bajos
                if humedad < 0.2 and temperatura > 25:
                    resultado = TipoBioma.DESIERTO
                elif humedad > 0.7 and temperatura > 15:
                    resultado = TipoBioma.JUNGLA
                elif humedad > 0.5:
                    resultado = TipoBioma.BOSQUE
                else:
                    resultado = TipoBioma.PRADERA
            elif altitud < 200:     # Colinas y terrenos elevados
                if humedad > 0.6 and temperatura > 10:
                    resultado = TipoBioma.BOSQUE
                elif humedad > 0.3:
                    resultado = TipoBioma.PRADERA
                else:
                    resultado = TipoBioma.DESIERTO
            elif altitud < 500:     # Montañas bajas
                if temperatura < 5:
                    resultado = TipoBioma.TUNDRA
                elif humedad > 0.4:
                    resultado = TipoBioma.BOSQUE
                else:
                    resultado = TipoBioma.DESIERTO
            elif altitud < 800:     # Montañas medias
                if temperatura < 0:
                    resultado = TipoBioma.TUNDRA
                elif humedad > 0.3:
                    resultado = TipoBioma.BOSQUE
                else:
                    resultado = TipoBioma.DESIERTO
            else:                   # Montañas altas (800+ metros)
                if temperatura < -5:
                    resultado = TipoBioma.TUNDRA
                elif humedad > 0.2:
                    resultado = TipoBioma.BOSQUE
                else:
                    resultado = TipoBioma.DESIERTO
            
            Logger.LogInfo("GeneradorBiomas: Tipo de bioma determinado")
            return resultado
        catch error as Exception:
            Logger.LogError("GeneradorBiomas: Error determinando tipo de bioma - " + error.Message)
            return TipoBioma.PRADERA  # Por defecto seguro
    
    function ObtenerAltitudBaseConSeed(coord: CoordenadaGlobal, seed: int): float
        try:
            # Generador de ruido con seed específica
            generador = new GeneradorPerlin(seed + 100)  # Offset para biomas
            
            # Generar altura usando coordenadas globales
            x_global = coord.chunk_x * 10 + coord.local_x
            z_global = coord.chunk_z * 10 + coord.local_z
            
            # Combinar múltiples octavas para variación natural
            ruido_1 = generador.Noise2D(x_global * 0.01, z_global * 0.01) * 50.0
            ruido_2 = generador.Noise2D(x_global * 0.02, z_global * 0.02) * 25.0
            ruido_3 = generador.Noise2D(x_global * 0.005, z_global * 0.005) * 10.0
            
            # Combinar ruidos para terreno complejo
            altura_base = ruido_1 + ruido_2 + ruido_3
            
            # Normalizar a rango -100 a 1000 metros
            altura_normalizada = (altura_base + 1.0) * 0.5
            altura_final = altura_normalizada * 1100.0 - 100.0
            
            return clamp(altura_final, -100.0, 1000.0)
        catch error as Exception:
            Logger.LogError("GeneradorBiomas: Error obteniendo altitud base - " + error.Message)
            return 0.0  # Por defecto: nivel del mar
    
    function ObtenerHumedadBaseConSeed(coord: CoordenadaGlobal, seed: int): float
        try:
            generador = new GeneradorPerlin(seed + 2000)  # Offset para humedad
            
            x_global = coord.chunk_x * 10 + coord.local_x
            z_global = coord.chunk_z * 10 + coord.local_z
            
            humedad_base = generador.Noise2D(x_global * 0.05, z_global * 0.05)
            
            # Normalizar a rango [0, 1]
            return (humedad_base + 1.0) * 0.5
        catch error as Exception:
            Logger.LogError("GeneradorBiomas: Error obteniendo humedad base - " + error.Message)
            return 0.5  # Por defecto: humedad media
    
    function ObtenerTemperaturaBaseConSeed(coord: CoordenadaGlobal, seed: int): float
        try:
            generador = new GeneradorPerlin(seed + 3000)  # Offset para temperatura
            
            x_global = coord.chunk_x * 10 + coord.local_x
            z_global = coord.chunk_z * 10 + coord.local_z
            
            temperatura_base = generador.Noise2D(x_global * 0.03, z_global * 0.03)
            
            # Normalizar a rango [0, 40] grados Celsius
            return (temperatura_base + 1.0) * 20.0
        catch error as Exception:
            Logger.LogError("GeneradorBiomas: Error obteniendo temperatura base - " + error.Message)
            return 20.0  # Por defecto: temperatura ambiente


# =============================================================================
# FUNCIONES AUXILIARES DE GENERACIÓN
# =============================================================================

function GenerarRuidoPerlinConSeed(x: int, z: int, frecuencia: float, seed: int): float
    try:
        # Generador de ruido con seed específica para reproducibilidad
        generador = new GeneradorPerlin(seed)
        return generador.Noise2D(x * frecuencia, z * frecuencia)
    catch error as Exception:
        Logger.LogError("GeneradorRuido: Error generando ruido Perlin - " + error.Message)
        return 0.0  # Por defecto: sin ruido

function ValidarElementoVegetacion(elemento: ElementoVegetacion): bool
    try:
        # Validar integridad básica del elemento
        if elemento == null:
            return false
        
        # Validar coordenadas
        if elemento.x < 0 or elemento.x > 9 or elemento.z < 0 or elemento.z > 9:
            return false
        
        # Validar tipo
        if elemento.tipo == null or elemento.tipo == "":
            return false
        
        return true
    catch error as Exception:
        Logger.LogError("Validacion: Error validando elemento vegetación - " + error.Message)
        return false

function ValidarElementoRecurso(elemento: ElementoRecurso): bool
    try:
        # Validar integridad básica del elemento
        if elemento == null:
            return false
        
        # Validar coordenadas
        if elemento.x < 0 or elemento.x > 9 or elemento.z < 0 or elemento.z > 9:
            return false
        
        # Validar tipo
        if elemento.tipo == null or elemento.tipo == "":
            return false
        
        # Validar cantidad (si aplica)
        if elemento.cantidad < 0 or elemento.cantidad > 100:
            return false
        
        return true
    catch error as Exception:
        Logger.LogError("Validacion: Error validando elemento recurso - " + error.Message)
        return false
