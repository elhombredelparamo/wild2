    static TRANSACCION_JUGADOR = 8
    static TRANSACCION_CHUNK = 9
    static TRANSACCION_ACCION = 10
    static TRANSACCION_TERRENO = 11
    static TRANSACCION_INVENTARIO = 12
    static ESTADO_JUGADOR = 13
    static ESTADO_CHUNK = 14
    static SOLICITUD_ESTADO_INICIAL = 15

