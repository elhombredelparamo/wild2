# FUNCIONES DE ACCESO (DEPRECATED)
# =============================================================================
# NOTA: Estas funciones están obsoletas y violan el principio de evitar referencias circulares
# Se deben eliminar y reemplazar por inyección de dependencias desde GameManager
# =============================================================================

function GetSistemaRed(): SistemaRed
    return ManejoErrores.EjecutarConManejo(() => {
        if GameManager.instance == null:
            Logger.LogError("GetSistemaRed: GameManager no inicializado")
            return EstadoSeguroRed.ObtenerValorPorDefecto("conexion_nula")
        return GameManager.instance.sistema_red
    }, "GetSistemaRed", false)

function IniciarServidor(puerto: int, max_jugadores: int): bool
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRed()
        if sistema != null:
            return sistema.IniciarServidor(puerto, max_jugadores)
        return EstadoSeguroRed.ObtenerValorPorDefecto("iniciar_servidor_fallido")
    }, "IniciarServidor", false)

function ConectarCliente(ip: string, puerto: int): bool
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRed()
        if sistema != null:
            return sistema.ConectarCliente(ip, puerto)
        return EstadoSeguroRed.ObtenerValorPorDefecto("conectar_cliente_fallido")
    }, "ConectarCliente", false)

function DesconectarRed():
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRed()
        if sistema != null:
            sistema.Desconectar()
        return true
    }, "DesconectarRed", false)

# =============================================================================
# FUNCIONES DE OPTIMIZACIÓN DE RED
# =============================================================================
function ComprimirMensajes(mensajes: List<MensajeRed>): List<MensajeRed>
    return ManejoErrores.EjecutarConManejo(() => {
        # Implementar compresión de mensajes para optimizar ancho de banda
        mensajes_comprimidos = new List<MensajeRed>()
        
        for mensaje in mensajes:
            # Simulación de compresión
            mensaje_comprimido = ComprimirMensaje(mensaje)
            if mensaje_comprimido != null:
                mensajes_comprimidos.Add(mensaje_comprimido)
        
        Logger.LogDebug("Red: Mensajes comprimidos de " + mensajes.length().ToString() + " a " + mensajes_comprimidos.length().ToString())
        return mensajes_comprimidos
    }, "ComprimirMensajes", false)

function ComprimirMensaje(mensaje: MensajeRed): MensajeRed
    return ManejoErrores.EjecutarConManejo(() => {
        # Simulación de compresión
        # (Aquí iría la implementación real de compresión)
        return mensaje  # Por ahora, retornar el mensaje sin cambios
    }, "ComprimirMensaje", false)

function BatchMensajes(mensajes: List<MensajeRed>): List<MensajeRed>
    return ManejoErrores.EjecutarConManejo(() => {
        # Agrupar mensajes pequeños en batches para reducir overhead
        if mensajes.length() <= 1:
            return mensajes
        
        batches = new List<MensajeRed>()
        batch_actual = new List<MensajeRed>()
        
        for mensaje in mensajes:
            if batch_actual.length() < 10:  # Batch de 10 mensajes
                batch_actual.Add(mensaje)
            else:
                # Crear batch message
                batch_msg = CrearBatchMessage(batch_actual)
                if batch_msg != null:
                    batches.Add(batch_msg)
                batch_actual.Clear()
                batch_actual.Add(mensaje)
        
        # Agregar último batch si hay mensajes pendientes
        if batch_actual.length() > 0:
            batch_msg = CrearBatchMessage(batch_actual)
            if batch_msg != null:
                batches.Add(batch_msg)
        
        Logger.LogDebug("Red: Mensajes batcheados de " + mensajes.length().ToString() + " a " + batches.length().ToString())
        return batches
    }, "BatchMensajes", false)

function CrearBatchMessage(mensajes: List<MensajeRed>): MensajeRed
    return ManejoErrores.EjecutarConManejo(() => {
        # Simulación de creación de batch
        # (Aquí iría la implementación real)
        return mensajes[0]  # Por ahora, retornar el primer mensaje
    }, "CrearBatchMessage", false)

# =============================================================================
# FUNCIONES DE MONITOREO
# =============================================================================
function ObtenerEstadisticasRed(): Dictionary<string, object>
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRed()
        if sistema != null:
            stats = new Dictionary()
            stats["es_servidor"] = SessionData.Instance.es_servidor
            stats["es_cliente"] = SessionData.Instance.es_cliente
            stats["esta_conectado"] = sistema.conexion.esta_conectado
            stats["clientes_conectados"] = sistema.conexion.clientes_conectados.length()
            stats["max_jugadores"] = sistema.gestor_jugadores.max_jugadores
            return stats
        return EstadoSeguroRed.ObtenerValorPorDefecto("estadisticas_vacias")
    }, "ObtenerEstadisticasRed", false)

function ObtenerPingPromedio(): float
    return ManejoErrores.EjecutarConManejo(() => {
        # Simulación de cálculo de ping
        return EstadoSeguroRed.ObtenerValorPorDefecto("ping_promedio")
    }, "ObtenerPingPromedio", false)

function ObtenerAnchoDeBanda(): float
    return ManejoErrores.EjecutarConManejo(() => {
        # Simulación de cálculo de ancho de banda (KB/s)
        return EstadoSeguroRed.ObtenerValorPorDefecto("ancho_banda")
    }, "ObtenerAnchoDeBanda", false)
