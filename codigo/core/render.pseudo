function GetMatrixMVP(transform): Matrix4
    try:
        sistema = GetSistemaRender()
        if sistema != null and sistema.camera_principal != null:
            return sistema.camera_principal.matriz_proyeccion * sistema.camera_principal.matriz_vista * transform.GetMatrix()
        else:
            Logger.LogWarning("GetMatrixMVP: SistemaRender o cámara no disponible")
            return Matrix4.IDENTITY
    catch error as Exception:
        Logger.LogError("GetMatrixMVP: Error calculando MVP: " + error.Message)
        return Matrix4.IDENTITY

function ActualizarMatrices():
    try:
        sistema = GetSistemaRender()
        if sistema != null and sistema.camera_principal != null:
            sistema.camera_principal.ActualizarMatrizProyeccion()
            sistema.camera_principal.ActualizarMatrizVista()
        else:
            Logger.LogWarning("ActualizarMatrices: SistemaRender o cámara no disponible")
    catch error as Exception:
        Logger.LogError("ActualizarMatrices: Error actualizando matrices: " + error.Message)

function SetViewport(x, y, ancho, alto):
    try:
        # Validar parámetros
        if ancho <= 0 or alto <= 0:
            Logger.LogWarning("SetViewport: Dimensiones inválidas")
            return
        
        # Configurar viewport
        RenderingServer.viewport_set_size(0, ancho, alto)
        RenderingServer.viewport_set_position(0, x, y)
        
        Logger.LogDebug("SetViewport: Viewport configurado - " + ancho.ToString() + "x" + alto.ToString())
    catch error as Exception:
        Logger.LogError("SetViewport: Error configurando viewport: " + error.Message)

function ClearColor(color):
    try:
        # Limpiar color de fondo
        RenderingServer.clear_default_color(color)
    catch error as Exception:
        Logger.LogError("ClearColor: Error limpiando color: " + error.Message)

function ClearDepth(valor):
    try:
        # Limpiar buffer de profundidad
        RenderingServer.clear_depth_buffer()
    catch error as Exception:
        Logger.LogError("ClearDepth: Error limpiando depth: " + error.Message)

function GetAnchoPantalla(): int
    try:
        return DisplayServer.screen_get_size().x
    catch error as Exception:
        Logger.LogError("GetAnchoPantalla: Error obteniendo ancho: " + error.Message)
        return 1920  # Fallback

function GetAltoPantalla(): int
    try:
        return DisplayServer.screen_get_size().y
    catch error as Exception:
        Logger.LogError("GetAltoPantalla: Error obteniendo alto: " + error.Message)
        return 1080  # Fallback

function GetAspectRatio(): float
    try:
        ancho = GetAnchoPantalla()
        alto = GetAltoPantalla()
        if alto > 0:
            return float(ancho) / float(alto)
        else:
            return 16.0 / 9.0  # Fallback
    catch error as Exception:
        Logger.LogError("GetAspectRatio: Error obteniendo aspect ratio: " + error.Message)
        return 16.0 / 9.0

function SwapBuffers():
    try:
        # Intercambiar buffers
        RenderingServer.frame_draw()
    catch error as Exception:
        Logger.LogError("SwapBuffers: Error intercambiando buffers: " + error.Message)

