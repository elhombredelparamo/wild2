# =============================================================================
# FUNCIONES GLOBALES DE ACCESO RÁPIDO
# =============================================================================
# FUNCIONES DE ACCESO (DEPRECATED)
# =============================================================================
# NOTA: Estas funciones están obsoletas y violan el principio de evitar referencias circulares
# Se deben eliminar y reemplazar por inyección de dependencias desde GameManager
# =============================================================================

function GetSistemaRender(): SistemaRender
    return ManejoErrores.EjecutarConManejo(() => {
        if GameManager.instance == null:
            Logger.LogError("GetSistemaRender: GameManager no inicializado")
            return EstadoSeguroRender.ObtenerValorPorDefecto("render_nulo")
        return GameManager.instance.sistema_render
    }, "GetSistemaRender", false)

function InicializarRender(seed: int = 0): SistemaRender
    # NOTA: Esta función está obsoleta y viola el principio de evitar referencias circulares
    # Se debe usar GameManager.instance.sistema_render.Inicializar()
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = new SistemaRender()
        sistema.Inicializar()
        if sistema != null:
            Logger.LogInfo("Render: Sistema inicializado correctamente")
        return sistema
    }, "InicializarRender", false)

function CambiarCalidadRender(calidad: NivelCalidad):
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRender()
        if sistema != null:
            sistema.ConfigurarCalidad(calidad)
            Logger.LogInfo("Render: Calidad cambiada a " + calidad.ToString())
        else:
            Logger.LogError("Render: No se pudo cambiar calidad - SistemaRender no disponible")
        return true
    }, "CambiarCalidadRender", false)

function ObtenerEstadisticasRender(): Dictionary<string, object>
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRender()
        if sistema != null:
            return sistema.ObtenerEstadisticas()
        else:
            return EstadoSeguroRender.ObtenerValorPorDefecto("estadisticas_vacias")
    }, "ObtenerEstadisticasRender", false)

function ObtenerFPS(): float
    return ManejoErrores.EjecutarConManejo(() => {
        sistema = GetSistemaRender()
        if sistema != null:
            return sistema.GetFPSActual()
        else:
            return EstadoSeguroRender.ObtenerValorPorDefecto("fps_actual")
    }, "ObtenerFPS", false)

