            return efectos_activos
        catch error as Exception:
            Logger.LogError("SistemaPostProcesado: Error obteniendo efectos activos: " + error.Message)
            return new Dictionary()

# =============================================================================
# CLASES AUXILIARES (Mejoradas)
# =============================================================================
class LuzDireccional:
    color: Color
    direccion: Vector3
    intensidad: float
    seed_mundo: int
    
    function Constructor(seed: int = 0):
        try:
            seed_mundo = seed
            color = COLOR_SOL
            direccion = Vector3(0.5, -1.0, 0.3).normalized()
            intensidad = 1.0
        catch error as Exception:
            Logger.LogError("LuzDireccional: Error en constructor: " + error.Message)
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            # Ajustar dirección basada en seed
            offset = (seed % 360) * PI / 180.0
            direccion = Vector3(
                sin(offset) * 0.5,
                -1.0,
                cos(offset) * 0.3
            ).normalized()
            Logger.LogInfo("LuzDireccional: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("LuzDireccional: Error configurando seed: " + error.Message)

class LuzPunto:
    color: Color
    posicion: Vector3
    intensidad: float
    radio: float
    seed_mundo: int
    
    function Constructor(pos: Vector3, seed: int = 0):
        try:
            seed_mundo = seed
            color = COLOR_BLANCO
            posicion = pos
            intensidad = 1.0
            radio = 10.0
            
            # Validar posición (rango de alturas -100 a 1000)
            if posicion.y < -100 or posicion.y > 1000:
                Logger.LogWarning("LuzPunto: Posición fuera de rango de alturas")
                posicion.y = clamp(posicion.y, -100, 1000)
        catch error as Exception:
            Logger.LogError("LuzPunto: Error en constructor: " + error.Message)

class LuzSpot:
    color: Color
    posicion: Vector3
    direccion: Vector3
    intensidad: float
    radio: float
    angulo: float
    seed_mundo: int
    
    function Constructor(pos: Vector3, dir: Vector3, seed: int = 0):
        try:
            seed_mundo = seed
            color = COLOR_BLANCO
            posicion = pos
            direccion = dir.normalized()
            intensidad = 1.0
            radio = 15.0
            angulo = 45.0
            
            # Validar posición y dirección
            if posicion.y < -100 or posicion.y > 1000:
                Logger.LogWarning("LuzSpot: Posición fuera de rango de alturas")
                posicion.y = clamp(posicion.y, -100, 1000)
        catch error as Exception:
            Logger.LogError("LuzSpot: Error en constructor: " + error.Message)

# =============================================================================
# CLASES DE MATERIALES Y SHADERS (Mejoradas)
# =============================================================================
class SistemaMateriales:
    materiales_terreno: Dictionary<int, Material>
    materiales_jugador: Dictionary<string, Material>
    calidad_actual: NivelCalidad
    seed_mundo: int
    
    function Inicializar(seed: int = 0):
        try:
            seed_mundo = seed
            materiales_terreno = new Dictionary()
            materiales_jugador = new Dictionary()
            
            # Cargar materiales base
            CargarMaterialesBase()
            
            Logger.LogInfo("SistemaMateriales: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error inicializando: " + error.Message)
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        try:
            calidad_anterior = calidad_actual
            calidad_actual = calidad
            
            # Recargar materiales con nueva calidad
            RecargarMateriales()
            
            Logger.LogInfo("SistemaMateriales: Calidad cambiada de " + calidad_anterior.ToString() + " a " + calidad.ToString())
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error configurando calidad: " + error.Message)
    
    function ObtenerMaterialTerreno(lod: int, calidad: NivelCalidad): Material
        try:
            clave = "lod_" + lod.ToString() + "_" + calidad.ToString()
            if materiales_terreno.ContainsKey(clave):
                return materiales_terreno[clave]
            else:
                # Generar material dinámicamente
                material = GenerarMaterialTerreno(lod, calidad)
                materiales_terreno[clave] = material
                return material
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error obteniendo material terreno: " + error.Message)
            return GetMaterialPorDefecto()
    
    function ObtenerModeloJugador(ruta: string): Modelo
        try:
            # Usar resource loader para cargar modelo
            loader = GetSistemaRender().resource_loader
            if loader != null:
                modelo = loader.CargarModelo(ruta)
                if modelo != null:
                    return modelo
            
            # Fallback: modelo por defecto
            return GetModeloJugadorPorDefecto()
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error obteniendo modelo jugador: " + error.Message)
            return GetModeloJugadorPorDefecto()
    
    function CargarMaterialesBase():
        try:
            # Cargar materiales base según calidad
            # (Aquí iría la implementación real)
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error cargando materiales base: " + error.Message)
    
    function RecargarMateriales():
        try:
            # Recargar todos los materiales
            materiales_terreno.Clear()
            materiales_jugador.Clear()
            CargarMaterialesBase()
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error recargando materiales: " + error.Message)
    
    function GenerarMaterialTerreno(lod: int, calidad: NivelCalidad): Material
        try:
            # Generar material dinámicamente
            material = new Material()
            
            # Configurar según LOD y calidad
            material.SetShader("terrain_shader")
            material.SetUniform("lod", lod)
            material.SetUniform("calidad", calidad)
            material.SetUniform("seed", seed_mundo)
            
            return material
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error generando material terreno: " + error.Message)
            return GetMaterialPorDefecto()
    
    function GetMaterialPorDefecto(): Material
        try:
            # Material por defecto simple
            material = new Material()
            material.SetShader("basic_shader")
            material.SetUniform("color", COLOR_GRIS)
            return material
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error obteniendo material por defecto: " + error.Message)
            return null
    
    function GetModeloJugadorPorDefecto(): Modelo
        try:
            # Modelo simple por defecto
            modelo = new Modelo()
            modelo.CargarDesdeMemoria("player_default")
            return modelo
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error obteniendo modelo por defecto: " + error.Message)
            return null
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            RecargarMateriales()
            Logger.LogInfo("SistemaMateriales: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaMateriales: Error configurando seed: " + error.Message)

class SistemaShaders:
    shaders_cargados: Dictionary<string, Shader>
    calidad_actual: NivelCalidad
    seed_mundo: int
    
    function Inicializar(seed: int = 0):
        try:
            seed_mundo = seed
            shaders_cargados = new Dictionary()
            
            # Cargar shaders base
            CargarShadersBase()
            
            Logger.LogInfo("SistemaShaders: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error inicializando: " + error.Message)
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        try:
            calidad_anterior = calidad_actual
            calidad_actual = calidad
            
            # Recompilar shaders con nueva calidad
            RecompilarShaders()
            
            Logger.LogInfo("SistemaShaders: Calidad cambiada de " + calidad_anterior.ToString() + " a " + calidad.ToString())
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error configurando calidad: " + error.Message)
    
    function CargarShadersBase():
        try:
            # Cargar shaders base
            shaders_cargados["terrain"] = CargarShader("terrain_shader")
            shaders_cargados["player"] = CargarShader("player_shader")
            shaders_cargados["vegetation"] = CargarShader("vegetation_shader")
            shaders_cargados["water"] = CargarShader("water_shader")
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error cargando shaders base: " + error.Message)
    
    function RecompilarShaders():
        try:
            # Recompilar todos los shaders
            for nombre, shader in shaders_cargados:
                shader.RecompilarConCalidad(calidad_actual)
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error recompilando shaders: " + error.Message)
    
    function CargarShader(ruta: string): Shader
        try:
            # Cargar shader desde archivo
            shader = new Shader()
            shader.CargarDesdeArchivo(ruta)
            shader.SetSeed(seed_mundo)
            return shader
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error cargando shader: " + error.Message)
            return GetShaderPorDefecto()
    
    function GetShaderPorDefecto(): Shader
        try:
            # Shader simple por defecto
            shader = new Shader()
            shader.CargarDesdeMemoria("basic_shader")
            return shader
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error obteniendo shader por defecto: " + error.Message)
            return null
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            RecompilarShaders()
            Logger.LogInfo("SistemaShaders: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaShaders: Error configurando seed: " + error.Message)

