function LogPerformance(contexto: string, tiempo: float):
    return ManejoErrores.EjecutarConManejo(() => {
        mensaje = "[PERF] " + contexto + ": " + tiempo.ToString("F3") + "s"
        if tiempo > 0.016:  # Más de 16.67ms (60 FPS)
            Logger.LogWarning(mensaje)
        else:
            Logger.LogDebug(mensaje)
        return true
    }, "LogPerformance", false)

function LogMemoriaRender(contexto: string, memoria: int):
    return ManejoErrores.EjecutarConManejo(() => {
        memoria_mb = memoria / (1024 * 1024)
        mensaje = "[MEM] " + contexto + ": " + memoria_mb.ToString("F1") + "MB"
        if memoria_mb > 500:  # Más de 500MB
            Logger.LogWarning(mensaje)
        else:
            Logger.LogDebug(mensaje)
        return true
    }, "LogMemoriaRender", false)

function LogRender(contexto: string, estado: string):
    return ManejoErrores.EjecutarConManejo(() => {
        mensaje = "[RENDER] " + contexto + ": " + estado
        Logger.LogInfo(mensaje)
        return true
    }, "LogRender", false)

# =============================================================================
# CONSTANTES Y CONFIGURACIÓN
# =============================================================================
const COLOR_CIELO = Color(0.5, 0.7, 1.0, 1.0)  # Azul cielo
const COLOR_SOL = Color(1.0, 0.9, 0.7, 1.0)     # Amarillo sol
const COLOR_BLANCO = Color(1.0, 1.0, 1.0, 1.0)   # Blanco
const COLOR_GRIS = Color(0.5, 0.5, 0.5, 1.0)    # Gris

# Niveles de calidad (deben coincidir con SistemaCalidad)
class NivelCalidad:
    static TOASTER = 0    # Mínimo
    static LOW = 1        # Bajo
    static MEDIUM = 2     # Medio
    static HIGH = 3       # Alto
    static ULTRA = 4      # Ultra

# Tipos de renderizado
class TipoRenderizado:
    static FORWARD = 0    # Forward rendering
    static DEFERRED = 1    # Deferred rendering
    static FORWARD_PLUS = 2  # Forward+

# Estados de renderizado
class EstadoRender:
    static INACTIVO = 0    # No renderizando
    static ACTIVO = 1     # Renderizando
    static PAUSADO = 2     # Renderizado pausado
    static ERROR = 3       # Error en renderizado
