# =============================================================================
# SISTEMA DE RENDER
# =============================================================================
# Archivo: render.pseudo
# Descripción: Pipeline de renderizado y gestión gráfica
# Autor: Cascade
# Fecha: 2026-03-11

# =============================================================================
# CLASE PRINCIPAL: SistemaRender (Singleton)
# =============================================================================
class SistemaRender:
    # Propiedades principales
    # calidad_actual eliminada - ahora usa SessionData.Instance.nivel_calidad
    camera_principal: Camera
    sistema_luces: SistemaLuces
    sistema_materiales: SistemaMateriales
    sistema_shaders: SistemaShaders
    sistema_lod: SistemaLOD
    sistema_postprocesado: SistemaPostProcesado
    resource_loader: DynamicResourceLoader
    # seed_mundo eliminada - ahora usa SessionData.Instance.seed_mundo
    
    # Métricas de rendimiento
    fps_actual: float = 60.0
    frame_tiempo: float = 0.016667  # 60 FPS
    draw_calls: int = 0
    triangles_renderizados: int = 0
    
    # =============================================================================
    # FUNCIONES PRINCIPALES
    # =============================================================================
    
    # Inicialización del sistema
    function Inicializar():
        return ManejoErrores.EjecutarConManejo(() => {
            _InicializarInterno()
            Logger.LogInfo("SistemaRender: Sistema inicializado")
            return true
        }, "SistemaRender.Inicializar", true)
    
    # Inicialización interna
    function _InicializarInterno():
        return ManejoErrores.EjecutarConManejo(() => {
            # Usar SessionData.Instance.seed_mundo
            
            # Crear cámara principal
            camera_principal = new Camera()
            camera_principal.ConfigurarCamera()
            
            # Inicializar subsistemas
            sistema_luces = new SistemaLuces()
            sistema_materiales = new SistemaMateriales()
            sistema_shaders = new SistemaShaders()
            sistema_lod = new SistemaLOD()
            sistema_postprocesado = new SistemaPostProcesado()
            
            # Inicializar resource loader
            # NOTA: Esto debe ser reemplazado por inyección de dependencias
            if GameManager.instance != null:
                calidad_inicial = GameManager.instance.sistema_calidad.calidad_actual
                resource_loader = DynamicResourceLoader.Inicializar(calidad_inicial)
            
            # Configurar calidad inicial
            calidad_actual = SessionData.Instance.nivel_calidad
            ConfigurarCalidad(calidad_actual)
            
            Logger.LogInfo("SistemaRender: Inicializado con seed " + SessionData.Instance.seed_mundo.ToString() + " y calidad " + calidad_actual.ToString())
            return true
        }, "SistemaRender._InicializarInterno", false)
    
    # Renderizado del frame
    function RenderFrame(delta_time):
        return ManejoErrores.EjecutarConManejo(() => {
            # Iniciar métricas de rendimiento
            frame_inicio = Time.GetTicksMsec()
            draw_calls = 0
            triangles_renderizados = 0
            
            # Limpiar buffers
            LimpiarBuffers()
            
            # Actualizar cámara
            ActualizarCamera(delta_time)
            
            # Preparar escena
            PrepararEscena()
            
            # Renderizado principal
            RenderEscenaPrincipal()
            
            # Post-procesado
            if SessionData.Instance.nivel_calidad >= NivelCalidad.MEDIUM:
                sistema_postprocesado.AplicarEfectos()
                draw_calls += sistema_postprocesado.GetDrawCalls()
            
            # Renderizar UI
            RenderUI()
            draw_calls += GetUIDrawCalls()
            
            # Presentar frame
            PresentarFrame()
            
            # Calcular métricas
            frame_fin = Time.GetTicksMsec()
            frame_tiempo = (frame_fin - frame_inicio) / 1000.0
            fps_actual = 1.0 / frame_tiempo
            
            # Log de rendimiento (cada segundo)
            if randf() < frame_tiempo:  # Probabilidad de log ~1 vez por segundo
                LogPerformance("RenderFrame", frame_tiempo)
            
            return true
        }, "SistemaRender.RenderFrame", false)
    
    # =============================================================================
    # FUNCIONES DE CONFIGURACIÓN
    # =============================================================================
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        return ManejoErrores.EjecutarConManejo(() => {
            calidad_anterior = SessionData.Instance.nivel_calidad
            SessionData.Instance.nivel_calidad = calidad
            calidad_actual = calidad
            
            # Configurar cámara
            camera_principal.ConfigurarCalidad(calidad)
            
            # Configurar luces
            sistema_luces.ConfigurarCalidad(calidad)
            
            # Configurar materiales
            sistema_materiales.ConfigurarCalidad(calidad)
            
            # Configurar shaders
            sistema_shaders.ConfigurarCalidad(calidad)
            
            # Configurar LOD
            sistema_lod.ConfigurarCalidad(calidad)
            
            # Configurar post-procesado
            sistema_postprocesado.ConfigurarCalidad(calidad)
            
            # Actualizar resource loader
            if resource_loader != null:
                resource_loader.ActualizarCalidad(calidad)
            
            Logger.LogInfo("SistemaRender: Calidad cambiada de " + calidad_anterior.ToString() + " a " + calidad.ToString())
            return true
        }, "SistemaRender.ConfigurarCalidad", false)

# =============================================================================
# CLASE: EstadoSeguroRender
# =============================================================================
class EstadoSeguroRender:
    static valores_por_defecto: Dictionary<string, object>
    
    static function Inicializar():
        valores_por_defecto = new Dictionary()
        # Valores seguros para cada sistema
        valores_por_defecto["fps_actual"] = 60.0
        valores_por_defecto["frame_tiempo"] = 0.016667
        valores_por_defecto["draw_calls"] = 0
        valores_por_defecto["triangles_renderizados"] = 0
        valores_por_defecto["calidad_actual"] = NivelCalidad.MEDIUM
        valores_por_defecto["fov"] = 60.0
        valores_por_defecto["lejos"] = 1000.0
        valores_por_defecto["max_luces_punto"] = 8
        valores_por_defecto["max_luces_spot"] = 4
        valores_por_defecto["distancias_lod"] = [10.0, 25.0, 50.0, 100.0, 200.0]
        valores_por_defecto["render_nulo"] = null
        valores_por_defecto["material_nulo"] = null
        valores_por_defecto["shader_nulo"] = null
        valores_por_defecto["modelo_nulo"] = null
        valores_por_defecto["camara_nula"] = null
        valores_por_defecto["efectos_vacios"] = null
        valores_por_defecto["estadisticas_vacias"] = null
    
    static function ObtenerValorPorDefecto(contexto: string): object
        if valores_por_defecto.ContainsKey(contexto):
            return valores_por_defecto[contexto]
        else:
            Logger.LogWarning("EstadoSeguroRender: Sin valor por defecto para: " + contexto)
            return null  # Fallback seguro

# =============================================================================
# FUNCIONES DE RENDERIZADO
# =============================================================================
    
    function RenderEscenaPrincipal():
        return ManejoErrores.EjecutarConManejo(() => {
            # Configurar viewport
            ConfigurarViewport()
            
            # Renderizar terreno
            RenderTerreno()
            
            # Renderizar objetos
            RenderObjetos()
            
            # Renderizar jugadores
            RenderJugadores()
            
            # Renderizar vegetación
            RenderVegetacion()
            
            # Renderizar partículas
            if SessionData.Instance.nivel_calidad >= NivelCalidad.LOW:
                RenderParticulas()
            return true
        }, "SistemaRender.RenderEscenaPrincipal", false)
    
    function RenderTerreno():
        return ManejoErrores.EjecutarConManejo(() => {
            chunks_activos = GetSistemaTerreno().chunks_activos
            
            for coord, chunk in chunks_activos:
                if chunk.esta_activo and chunk.malla != null:
                    # Determinar LOD
                    lod = sistema_lod.ObtenerLOD(chunk, camera_principal.posicion)
                    
                    # Seleccionar material según calidad y LOD
                    material = sistema_materiales.ObtenerMaterialTerreno(lod, SessionData.Instance.nivel_calidad)
                    
                    # Renderizar chunk
                    if RenderChunk(chunk, material, lod):
                        draw_calls++
                        triangles_renderizados += chunk.malla.GetTriangleCount()
            return true
        }, "SistemaRender.RenderTerreno", false)
    
    function RenderJugadores():
        return ManejoErrores.EjecutarConManejo(() => {
            # Renderizar jugador local
            # NOTA: Esto debe ser reemplazado por inyección de dependencias
            if GameManager.instance != null:
                jugador_local = GameManager.instance.sistema_jugador.GetJugadorLocal()
                if jugador_local.esta_activo:
                    if RenderJugador(jugador_local):
                        draw_calls++
                
                # Renderizar jugadores remotos
                jugadores_remotos = GameManager.instance.sistema_jugador.jugadores_remotos
                for id, jugador in jugadores_remotos:
                    if RenderJugador(jugador):
                        draw_calls++
            return true
        }, "SistemaRender.RenderJugadores", false)
    
    function RenderJugador(jugador):
        return ManejoErrores.EjecutarConManejo(() => {
            # Validar jugador
            if jugador == null or not jugador.esta_activo:
                return EstadoSeguroRender.ObtenerValorPorDefecto("render_jugador_fallido")
            
            # Obtener modelo y animación usando resource loader
            modelo = resource_loader.CargarModeloJugador(jugador.apariencia.modelo_path)
            if modelo == null:
                Logger.LogWarning("SistemaRender: Modelo de jugador no encontrado")
                return EstadoSeguroRender.ObtenerValorPorDefecto("render_jugador_fallido")
            
            animacion = jugador.gestor_animaciones.GetAnimacionActual()
            
            # Validar posición (rango de alturas -100 a 1000)
            if jugador.posicion.y < -100 or jugador.posicion.y > 1000:
                Logger.LogWarning("SistemaRender: Posición de jugador fuera de rango")
                return EstadoSeguroRender.ObtenerValorPorDefecto("render_jugador_fallido")
            
            # Configurar transform
            transform = new Transform()
            transform.posicion = jugador.posicion
            transform.rotacion = jugador.rotacion
            
            # Renderizar
            return RenderModelo(modelo, transform, animacion)
        }, "SistemaRender.RenderJugador", false)
    
    # =============================================================================
    # FUNCIONES DE CÁMARA
    # =============================================================================
    
    function ActualizarCamera(delta_time):
        return ManejoErrores.EjecutarConManejo(() => {
            # Seguir jugador local
            # NOTA: Esto debe ser reemplazado por inyección de dependencias
            if GameManager.instance != null:
                jugador = GameManager.instance.sistema_jugador.GetJugadorLocal()
                
                if jugador != null and jugador.esta_activo:
                    # Validar posición del jugador
                    if jugador.posicion.y < -100 or jugador.posicion.y > 1000:
                        Logger.LogWarning("SistemaRender: Posición de jugador fuera de rango en cámara")
                        return EstadoSeguroRender.ObtenerValorPorDefecto("actualizar_camera_fallido")
                    
                    # Calcular posición objetivo
                    offset_camera = Vector3(0, 5, -10)  # Tercera persona
                    posicion_objetivo = jugador.posicion + offset_camera
                    
                    # Interpolar posición suave
                    factor_interp = min(1.0, 5.0 * delta_time)
                    camera_principal.posicion = camera_principal.posicion.lerp(posicion_objetivo, factor_interp)
                    
                    # Mirar al jugador
                    camera_principal.MirarA(jugador.posicion)
                    
                    Logger.LogDebug("SistemaRender: Cámara actualizada - Jugador: " + jugador.nombre)
            return true
        }, "SistemaRender.ActualizarCamera", false)
    
    # =============================================================================
    # FUNCIONES AUXILIARES
    # =============================================================================
    
    function LimpiarBuffers():
        return ManejoErrores.EjecutarConManejo(() => {
            # Limpiar color y depth
            ClearColor(COLOR_CIELO)
            ClearDepth(1.0)
            return true
        }, "SistemaRender.LimpiarBuffers", false)
    
    function PrepararEscena():
        return ManejoErrores.EjecutarConManejo(() => {
            # Actualizar matrices de transformación
            ActualizarMatrices()
            
            # Preparar luces para el frame
            sistema_luces.PrepararFrame()
            return true
        }, "SistemaRender.PrepararEscena", false)
    
    function ConfigurarViewport():
        return ManejoErrores.EjecutarConManejo(() => {
            # Configurar viewport principal
            SetViewport(0, 0, GetAnchoPantalla(), GetAltoPantalla())
            return true
        }, "SistemaRender.ConfigurarViewport", false)
    
    function RenderChunk(chunk, material, lod):
        return ManejoErrores.EjecutarConManejo(() => {
            # Validar chunk y material
            if chunk == null or chunk.malla == null or material == null:
                return EstadoSeguroRender.ObtenerValorPorDefecto("render_chunk_fallido")
            
            # Bind material
            material.Bind()
            
            # Setear uniforms
            material.SetUniform("matriz_mvp", GetMatrixMVP(chunk.transform))
            material.SetUniform("lod", lod)
            material.SetUniform("posicion_camera", camera_principal.posicion)
            material.SetUniform("seed_mundo", SessionData.Instance.seed_mundo)
            
            # Renderizar malla
            chunk.malla.Render()
            triangles_renderizados += chunk.malla.GetTriangleCount()
            
            # Unbind material
            material.Unbind()
            
            return true
        }, "SistemaRender.RenderChunk", false)
    
    function RenderModelo(modelo, transform, animacion):
        return ManejoErrores.EjecutarConManejo(() => {
            # Validar modelo y transform
            if modelo == null or transform == null:
                return EstadoSeguroRender.ObtenerValorPorDefecto("render_modelo_fallido")
            
            # Configurar animación
            if animacion != null:
                modelo.SetAnimacion(animacion)
            
            # Renderizar mallas del modelo
            for malla in modelo.mallas:
                if malla != null and malla.material != null:
                    material = malla.material
                    material.Bind()
                    
                    material.SetUniform("matriz_mvp", GetMatrixMVP(transform))
                    material.SetUniform("matriz_transform", transform.GetMatrix())
                    material.SetUniform("seed_mundo", SessionData.Instance.seed_mundo)
                    
                    malla.Render()
                    triangles_renderizados += malla.GetTriangleCount()
                    
                    material.Unbind()
            
            return true
        }, "SistemaRender.RenderModelo", false)
    
    function PresentarFrame():
        return ManejoErrores.EjecutarConManejo(() => {
            # Intercambiar buffers
            SwapBuffers()
            return true
        }, "SistemaRender.PresentarFrame", false)
    
    # =============================================================================
    # FUNCIONES DE MÉTRICAS
    # =============================================================================
    
    function GetFPSActual(): float
        return ManejoErrores.EjecutarConManejo(() => {
            return fps_actual
        }, "SistemaRender.GetFPSActual", false)
    
    function GetDrawCalls(): int
        return ManejoErrores.EjecutarConManejo(() => {
            return draw_calls
        }, "SistemaRender.GetDrawCalls", false)
    
    function GetTrianglesRenderizados(): int
        return ManejoErrores.EjecutarConManejo(() => {
            return triangles_renderizados
        }, "SistemaRender.GetTrianglesRenderizados", false)
    
    function GetCalidadActual(): NivelCalidad
        return ManejoErrores.EjecutarConManejo(() => {
            return SessionData.Instance.nivel_calidad
        }, "SistemaRender.GetCalidadActual", false)
    
    function ObtenerEstadisticas(): Dictionary<string, object>
        return ManejoErrores.EjecutarConManejo(() => {
            stats = new Dictionary()
            stats["fps"] = fps_actual
            stats["frame_tiempo"] = frame_tiempo
            stats["draw_calls"] = draw_calls
            stats["triangles"] = triangles_renderizados
            stats["calidad"] = SessionData.Instance.nivel_calidad.ToString()
            stats["chunks_renderizados"] = GetSistemaTerreno().chunks_activos.length()
            return stats
        }, "SistemaRender.ObtenerEstadisticas", false)

# =============================================================================
# CLASE: Camera (Mejorada)
# =============================================================================
class Camera:
    posicion: Vector3
    rotacion: Vector3
    fov: float = 60.0
    cerca: float = 0.1
    lejos: float = 1000.0
    matriz_proyeccion: Matrix4
    matriz_vista: Matrix4
    seed_mundo: int
    
    function ConfigurarCamera():
        return ManejoErrores.EjecutarConManejo(() => {
            ActualizarMatrizProyeccion()
            ActualizarMatrizVista()
            Logger.LogDebug("Camera: Cámara configurada")
            return true
        }, "Camera.ConfigurarCamera", false)
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        return ManejoErrores.EjecutarConManejo(() => {
            try:
                switch calidad:
                    case NivelCalidad.TOASTER:
                        fov = 45.0
                        lejos = 500.0
                    case NivelCalidad.LOW:
                        fov = 50.0
                        lejos = 750.0
                    case NivelCalidad.MEDIUM:
                        fov = 60.0
                        lejos = 1000.0
                    case NivelCalidad.HIGH:
                        fov = 70.0
                        lejos = 1500.0
                    case NivelCalidad.ULTRA:
                        fov = 75.0
                        lejos = 2000.0
                
                # Validar rango de alturas (-100 a 1000)
                if lejos > 2000:
                    Logger.LogWarning("Camera: Distancia de renderizado muy alta: " + lejos.ToString())
                    lejos = 2000.0
                
                ActualizarMatrizProyeccion()
                Logger.LogInfo("Camera: Calidad configurada - FOV: " + fov.ToString() + ", Lejos: " + lejos.ToString())
                return true
            catch error as Exception:
                Logger.LogError("Camera: Error configurando calidad: " + error.Message)
                return EstadoSeguroRender.ObtenerValorPorDefecto("configurar_calidad_fallido")
        }, "Camera.ConfigurarCalidad", false)
    
    function MirarA(objetivo: Vector3):
        return ManejoErrores.EjecutarConManejo(() => {
            # Validar objetivo
            if objetivo.y < -100 or objetivo.y > 1000:
                Logger.LogWarning("Camera: Objetivo fuera de rango de alturas")
                return EstadoSeguroRender.ObtenerValorPorDefecto("mirar_a_fallido")
            
            direccion = (objetivo - posicion).normalized()
            if direccion.length() > 0:
                rotacion = Quaternion.LookRotation(direccion)
                ActualizarMatrizVista()
            return true
        }, "Camera.MirarA", false)
    
    function ActualizarMatrizProyeccion():
        return ManejoErrores.EjecutarConManejo(() => {
            aspect_ratio = GetAspectRatio()
            if aspect_ratio <= 0:
                aspect_ratio = 16.0 / 9.0  # Fallback
            
            matriz_proyeccion = Matrix4.Perspective(fov, aspect_ratio, cerca, lejos)
            return true
        }, "Camera.ActualizarMatrizProyeccion", false)
    
    function ActualizarMatrizVista():
        return ManejoErrores.EjecutarConManejo(() => {
            matriz_vista = Matrix4.LookAt(posicion, posicion + forward, up)
            return true
        }, "Camera.ActualizarMatrizVista", false)
    
    function SetSeed(seed: int):
        return ManejoErrores.EjecutarConManejo(() => {
            # Usar SessionData.Instance.seed_mundo en lugar de variable local
            Logger.LogInfo("Camera: Seed configurada: " + SessionData.Instance.seed_mundo.ToString())
            return true
        }, "Camera.SetSeed", false)
    
    function GetPosicion(): Vector3
        return ManejoErrores.EjecutarConManejo(() => {
            return posicion
        }, "Camera.GetPosicion", false)
    
    function GetFOV(): float
        return ManejoErrores.EjecutarConManejo(() => {
            return fov
        }, "Camera.GetFOV", false)
    
    function GetDistanciaLejos(): float
        return ManejoErrores.EjecutarConManejo(() => {
            return lejos
        }, "Camera.GetDistanciaLejos", false)

# =============================================================================
# CLASE: SistemaLuces (Mejorada)
# =============================================================================
class SistemaLuces:
    luz_direccional: LuzDireccional
    luces_punto: List<LuzPunto>
    luces_spot: List<LuzSpot>
    max_luces_punto: int = 8
    max_luces_spot: int = 4
    seed_mundo: int
    
    function Inicializar(seed: int = 0):
        try:
            seed_mundo = seed
            
            # Crear luz direccional (sol)
            luz_direccional = new LuzDireccional()
            luz_direccional.color = COLOR_SOL
            luz_direccional.direccion = Vector3(0.5, -1.0, 0.3).normalized()
            luz_direccional.intensidad = 1.0
            
            luces_punto = new List()
            luces_spot = new List()
            
            Logger.LogInfo("SistemaLuces: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error inicializando: " + error.Message)
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        try:
            switch calidad:
                case NivelCalidad.TOASTER:
                    SetMaxLucesPunto(2)
                    SetMaxLucesSpot(1)
                case NivelCalidad.LOW:
                    SetMaxLucesPunto(4)
                    SetMaxLucesSpot(2)
                case NivelCalidad.MEDIUM:
                    SetMaxLucesPunto(8)
                    SetMaxLucesSpot(4)
                case NivelCalidad.HIGH:
                    SetMaxLucesPunto(16)
                    SetMaxLucesSpot(8)
                case NivelCalidad.ULTRA:
                    SetMaxLucesPunto(32)
                    SetMaxLucesSpot(16)
            
            Logger.LogInfo("SistemaLuces: Calidad configurada - Puntos: " + max_luces_punto.ToString() + ", Spots: " + max_luces_spot.ToString())
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error configurando calidad: " + error.Message)
    
    function SetMaxLucesPunto(maximo: int):
        try:
            if maximo >= 0 and maximo <= 64:
                max_luces_punto = maximo
                # Limitar luces existentes
                while luces_punto.length() > max_luces_punto:
                    luces_punto.RemoveAt(0)
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error configurando máximas luces punto: " + error.Message)
    
    function SetMaxLucesSpot(maximo: int):
        try:
            if maximo >= 0 and maximo <= 32:
                max_luces_spot = maximo
                # Limitar luces existentes
                while luces_spot.length() > max_luces_spot:
                    luces_spot.RemoveAt(0)
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error configurando máximas luces spot: " + error.Message)
    
    function PrepararFrame():
        try:
            # Actualizar luces dinámicas
            ActualizarLucesDinamicas()
            
            # Enviar datos al shader
            EnviarDatosLucesShader()
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error preparando frame: " + error.Message)
    
    function ActualizarLucesDinamicas():
        try:
            # Simulación de actualización de luces dinámicas
            # (Aquí iría la implementación real)
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error actualizando luces dinámicas: " + error.Message)
    
    function EnviarDatosLucesShader():
        try:
            # Enviar datos de luces al shader
            # (Aquí iría la implementación real)
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error enviando datos a shader: " + error.Message)
    
    function AgregarLuzPunto(luz: LuzPunto):
        try:
            if luces_punto.length() < max_luces_punto:
                luces_punto.Add(luz)
                Logger.LogDebug("SistemaLuces: Luz punto agregada")
            else:
                Logger.LogWarning("SistemaLuces: Límite de luces punto alcanzado")
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error agregando luz punto: " + error.Message)
    
    function AgregarLuzSpot(luz: LuzSpot):
        try:
            if luces_spot.length() < max_luces_spot:
                luces_spot.Add(luz)
                Logger.LogDebug("SistemaLuces: Luz spot agregada")
            else:
                Logger.LogWarning("SistemaLuces: Límite de luces spot alcanzado")
        catch error as Exception:
            Logger.LogError("SistemaLuces: Error agregando luz spot: " + error.Message)

# =============================================================================
# CLASE: SistemaLOD (Mejorada)
# =============================================================================
class SistemaLOD:
    distancias_lod: List<float> = [10.0, 25.0, 50.0, 100.0, 200.0]
    seed_mundo: int
    
    function Inicializar(seed: int = 0):
        try:
            seed_mundo = seed
            Logger.LogInfo("SistemaLOD: Inicializado con seed " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaLOD: Error inicializando: " + error.Message)
    
    function ObtenerLOD(chunk, posicion_camera): int
        try:
            # Validar chunk y posición
            if chunk == null or posicion_camera == null:
                return 0  # LOD más alto por defecto
            
            # Validar posición (rango de alturas -100 a 1000)
            if posicion_camera.y < -100 or posicion_camera.y > 1000:
                Logger.LogWarning("SistemaLOD: Posición de cámara fuera de rango")
                return 0
            
            distancia = (chunk.posicion - posicion_camera).length()
            
            # Usar seed para consistencia en cálculos de LOD
            distancia_ajustada = distancia * (1.0 + (seed_mundo % 100) / 1000.0)
            
            for i, dist in distancias_lod:
                if distancia_ajustada < dist:
                    return i
            
            return distancias_lod.length() - 1
        catch error as Exception:
            Logger.LogError("SistemaLOD: Error obteniendo LOD: " + error.Message)
            return 0
    
    function ConfigurarCalidad(calidad: NivelCalidad):
        try:
            switch calidad:
                case NivelCalidad.TOASTER:
                    distancias_lod = [5.0, 15.0, 30.0]
                case NivelCalidad.LOW:
                    distancias_lod = [8.0, 20.0, 40.0, 80.0]
                case NivelCalidad.MEDIUM:
                    distancias_lod = [10.0, 25.0, 50.0, 100.0]
                case NivelCalidad.HIGH:
                    distancias_lod = [15.0, 35.0, 70.0, 140.0, 250.0]
                case NivelCalidad.ULTRA:
                    distancias_lod = [20.0, 45.0, 90.0, 180.0, 350.0, 500.0]
            
            Logger.LogInfo("SistemaLOD: Calidad configurada - Niveles LOD: " + distancias_lod.length().ToString())
        catch error as Exception:
            Logger.LogError("SistemaLOD: Error configurando calidad: " + error.Message)
    
    function GetDistanciasLOD(): List<float>
        try:
            return distancias_lod
        catch error as Exception:
            Logger.LogError("SistemaLOD: Error obteniendo distancias LOD: " + error.Message)
            return [10.0, 25.0, 50.0, 100.0, 200.0]
    
    function SetSeed(seed: int):
        try:
            seed_mundo = seed
            Logger.LogInfo("SistemaLOD: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaLOD: Error configurando seed: " + error.Message)

