            Logger.LogInfo("SistemaPostProcesado: Seed configurada: " + seed.ToString())
        catch error as Exception:
            Logger.LogError("SistemaPostProcesado: Error configurando seed: " + error.Message)
    
    function GetEfectosActivos(): Dictionary<string, bool>
