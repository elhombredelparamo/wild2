class Dificultad:
    static FACIL = 0
    static NORMAL = 1
    static DIFICIL = 2
    static EXTREMO = 3

class QualityLevel:
    static Toaster = 0
    static Low = 1
    static Medium = 2
    static High = 3
    static Ultra = 4

class CalidadSombras:
    static BAJA = 0
    static MEDIA = 1
    static ALTA = 2
    static ULTRA = 3

class CalidadTexturas:
    static BAJA = 0
    static MEDIA = 1
    static ALTA = 2
    static ULTRA = 3

class CalidadAudio:
    static BAJA = 0
    static MEDIA = 1
    static ALTA = 2

# =============================================================================
# CLASES DE DATOS ADICIONALES
# =============================================================================

class HardwareInfo:
    ram_mb: int
    vram_mb: int
    cpu_cores: int
    gpu_nombre: string
    sistema_operativo: string
    
    function Constructor():
        return ManejoErrores.EjecutarConManejo(() => {
            ram_mb = OS.GetSystemMemoryMB()
            vram_mb = GetVRAMSizeMB()
            cpu_cores = OS.GetProcessorCount()
            gpu_nombre = GetGPUName()
            sistema_operativo = OS.GetName()
            
            Logger.LogInfo("HardwareInfo: Información de hardware detectada")
        }, "HardwareInfo.Constructor", false)

# =============================================================================
# FUNCIONES AUXILIARES
# =============================================================================
function SetPantallaCompleta(completa: bool)
function SetResolucion(ancho: int, alto: int)
function SetVSync(activo: bool)
function SetVolumenMaestro(volumen: float)
function SetVolumenMusica(volumen: float)
function SetVolumenEfectos(volumen: float)
function SetVolumenVoz(volumen: float)
function ObtenerInformacionHardware(): HardwareInfo
function GetVRAMSizeMB(): int
function GetGPUName(): string

