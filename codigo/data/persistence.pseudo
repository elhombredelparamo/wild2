# =============================================================================
# SISTEMA DE PERSISTENCIA SERVIDOR-CLIENTE
# =============================================================================
# Archivo: persistence.pseudo
# Descripción: Sistema de persistencia continua en servidor con archivos .dat
# Autor: Cascade
# Fecha: 2026-03-11

# =============================================================================
# CLASE PRINCIPAL: SistemaPersistenciaServidor
# =============================================================================
class SistemaPersistenciaServidor:
    # Singleton para acceso global (solo en servidor)
    static instance: SistemaPersistenciaServidor
    
    # Propiedades principales
    directorio_mundos: string
    mundo_actual: string
    es_servidor: bool
    cola_transacciones: Queue<TransaccionPersistencia>
    hilo_persistencia: Thread
    ejecutando: bool = true
    
    # =============================================================================
    # FUNCIONES PRINCIPALES
    # =============================================================================
    
    # Inicialización del sistema (solo servidor)
    static function InicializarServidor(directorio: string = "worlds/"):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("inicializacion_fallida")
            
            if instance == null:
                instance = new SistemaPersistenciaServidor()
            
            SessionData.Instance.directorio_mundos = directorio
            SessionData.Instance.es_servidor = true
            instance.cola_transacciones = new Queue()
            
            # Crear directorio si no existe
            instance.CrearDirectorioMundos()
            
            # Iniciar hilo de persistencia
            instance.IniciarHiloPersistencia()
            
            Logger.LogInfo("SistemaPersistenciaServidor: Servidor inicializado")
            return true
        }, "SistemaPersistenciaServidor.InicializarServidor", true)
    
    # Inicialización para clientes (sin persistencia local)
    static function InicializarCliente():
        return ManejoErrores.EjecutarConManejo(() => {
            # Los clientes no manejan persistencia local
            # Solo envían transacciones al servidor
            if SessionData.Instance != null:
                SessionData.Instance.es_servidor = false
            Logger.LogInfo("SistemaPersistenciaServidor: Cliente inicializado")
            return true
        }, "SistemaPersistenciaServidor.InicializarCliente", false)
    
    # =============================================================================
    # FUNCIONES DE PERSISTENCIA CONTINUA (SOLO SERVIDOR)
    # =============================================================================
    
    static function CrearMundo(nombre_mundo: string, configuracion: ConfiguracionMundo): bool
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
            
            if not SessionData.Instance.es_servidor:
                Logger.LogError("SistemaPersistenciaServidor: Solo el servidor puede crear mundos")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
            
            return instance.CrearNuevoMundo(nombre_mundo, configuracion)
        }, "SistemaPersistenciaServidor.CrearMundo", false)
    
    static function ConectarMundo(nombre_mundo: string): bool
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
            
            if not SessionData.Instance.es_servidor:
                Logger.LogError("SistemaPersistenciaServidor: Solo el servidor puede conectar mundos")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
            
            return instance.ConectarAMundo(nombre_mundo)
        }, "SistemaPersistenciaServidor.ConectarMundo", false)
    
    static function DesconectarMundo():
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                instance.DesconectarDeMundo()
            return true
        }, "SistemaPersistenciaServidor.DesconectarMundo", false)
    
    # =============================================================================
    # FUNCIONES DE GUARDADO (SOLO SERVIDOR)
    # =============================================================================
    
    static function PersistirJugador(jugador: JugadorLocal):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                transaccion = new TransaccionJugador(jugador)
                instance.AgregarTransaccion(transaccion)
            else:
                # Cliente envía transacción al servidor
                if GetSistemaRed() != null:
                    GetSistemaRed().EnviarTransaccionJugador(jugador)
                else:
                    Logger.LogWarning("SistemaPersistenciaServidor: SistemaRed no disponible")
            return true
        }, "SistemaPersistenciaServidor.PersistirJugador", false)
    
    static function PersistirChunk(chunk: Chunk):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                transaccion = new TransaccionChunk(chunk)
                instance.AgregarTransaccion(transaccion)
            else:
                # Cliente envía transacción al servidor
                if GetSistemaRed() != null:
                    GetSistemaRed().EnviarTransaccionChunk(chunk)
                else:
                    Logger.LogWarning("SistemaPersistenciaServidor: SistemaRed no disponible")
            return true
        }, "SistemaPersistenciaServidor.PersistirChunk", false)
    
    static function PersistirAccionJugador(accion: AccionJugador):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                transaccion = new TransaccionAccion(accion)
                instance.AgregarTransaccion(transaccion)
            else:
                # Cliente envía transacción al servidor
                if GetSistemaRed() != null:
                    GetSistemaRed().EnviarTransaccionAccion(accion)
                else:
                    Logger.LogWarning("SistemaPersistenciaServidor: SistemaRed no disponible")
            return true
        }, "SistemaPersistenciaServidor.PersistirAccionJugador", false)
    
    static function PersistirModificacionTerreno(modificacion: ModificacionTerreno):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                transaccion = new TransaccionTerreno(modificacion)
                instance.AgregarTransaccion(transaccion)
            else:
                # Cliente envía transacción al servidor
                if GetSistemaRed() != null:
                    GetSistemaRed().EnviarTransaccionTerreno(modificacion)
                else:
                    Logger.LogWarning("SistemaPersistenciaServidor: SistemaRed no disponible")
            return true
        }, "SistemaPersistenciaServidor.PersistirModificacionTerreno", false)
    
    static function PersistirInventario(inventario: Inventario):
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance != null and SessionData.Instance.es_servidor:
                transaccion = new TransaccionInventario(inventario)
                instance.AgregarTransaccion(transaccion)
            else:
                # Cliente envía transacción al servidor
                if GetSistemaRed() != null:
                    GetSistemaRed().EnviarTransaccionInventario(inventario)
                else:
                    Logger.LogWarning("SistemaPersistenciaServidor: SistemaRed no disponible")
            return true
        }, "SistemaPersistenciaServidor.PersistirInventario", false)

# =============================================================================
# CLASE: EstadoSeguroPersistencia
# =============================================================================
class EstadoSeguroPersistencia:
    static valores_por_defecto: Dictionary<string, object>
    
    static function Inicializar():
        valores_por_defecto = new Dictionary()
        # Valores seguros para cada sistema
        valores_por_defecto["directorio_mundos"] = "worlds/"
        valores_por_defecto["mundo_actual"] = null
        valores_por_defecto["es_servidor"] = false
        valores_por_defecto["cola_transacciones_vacia"] = null
        valores_por_defecto["hilo_persistencia_nulo"] = null
        valores_por_defecto["ejecutando"] = true
        valores_por_defecto["metadatos_nulos"] = null
        valores_por_defecto["configuracion_defecto"] = null
        valores_por_defecto["resultado_exitoso"] = null
        valores_por_defecto["resultado_fallido"] = null
        valores_por_defecto["datos_chunk_nulos"] = null
        valores_por_defecto["datos_personaje_nulos"] = null
        valores_por_defecto["ruta_vacia"] = ""
        valores_por_defecto["bytes_vacios"] = null
        valores_por_defecto["serializacion_fallida"] = null
        valores_por_defecto["deserializacion_fallida"] = null
        valores_por_defecto["inicializacion_fallida"] = false
        valores_por_defecto["crear_mundo_fallido"] = false
        valores_por_defecto["conectar_mundo_fallido"] = false
        valores_por_defecto["desconectar_mundo_fallido"] = false
        valores_por_defecto["persistir_jugador_fallido"] = false
        valores_por_defecto["persistir_chunk_fallido"] = false
        valores_por_defecto["persistir_accion_fallido"] = false
        valores_por_defecto["persistir_terreno_fallido"] = false
        valores_por_defecto["persistir_inventario_fallido"] = false
        valores_por_defecto["obtener_estado_jugador_fallido"] = null
        valores_por_defecto["obtener_estado_chunk_fallido"] = null
        valores_por_defecto["obtener_lista_mundos_fallida"] = null
        valores_por_defecto["existe_mundo_fallido"] = false
        valores_por_defecto["crear_nuevo_mundo_fallido"] = false
        valores_por_defecto["conectar_a_mundo_fallido"] = false
        valores_por_defecto["desconectar_de_mundo_fallido"] = false
        valores_por_defecto["agregar_transaccion_fallida"] = false
        valores_por_defecto["iniciar_hilo_fallido"] = false
        valores_por_defecto["bucle_persistencia_fallido"] = false
        valores_por_defecto["procesar_transaccion_fallida"] = false
        valores_por_defecto["procesar_jugador_fallido"] = false
        valores_por_defecto["procesar_chunk_fallido"] = false
        valores_por_defecto["procesar_accion_fallida"] = false
        valores_por_defecto["procesar_terreno_fallido"] = false
        valores_por_defecto["procesar_inventario_fallido"] = false
        valores_por_defecto["crear_directorio_fallido"] = false
        valores_por_defecto["crear_estructura_fallida"] = false
        valores_por_defecto["obtener_ruta_jugador_fallida"] = ""
        valores_por_defecto["obtener_ruta_chunk_fallida"] = ""
        valores_por_defecto["obtener_ruta_log_fallida"] = ""
        valores_por_defecto["obtener_ruta_eventos_fallida"] = ""
        valores_por_defecto["obtener_ruta_seed_fallida"] = ""
        valores_por_defecto["obtener_ruta_metadata_fallida"] = ""
        valores_por_defecto["procesar_todas_fallido"] = false
        valores_por_defecto["generar_semilla_fallida"] = 0
    
    static function ObtenerValorPorDefecto(contexto: string): object
        if valores_por_defecto.ContainsKey(contexto):
            return valores_por_defecto[contexto]
        else:
            Logger.LogWarning("EstadoSeguroPersistencia: Sin valor por defecto para: " + contexto)
            return null  # Fallback seguro

# =============================================================================
# FUNCIONES DE CONSULTA (SOLO SERVIDOR)
# =============================================================================
    
    static function ObtenerEstadoJugador(nombre_jugador: string): EstadoJugadorPersistido
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_estado_jugador_fallido")
            
            if not SessionData.Instance.es_servidor:
                Logger.LogError("SistemaPersistenciaServidor: Solo el servidor puede consultar estados")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_estado_jugador_fallido")
            
            return instance.CargarEstadoJugador(nombre_jugador)
        }, "SistemaPersistenciaServidor.ObtenerEstadoJugador", false)
    
    static function ObtenerEstadoChunk(coordenada: CoordenadaGlobal): DatosChunk
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_estado_chunk_fallido")
            
            if not SessionData.Instance.es_servidor:
                Logger.LogError("SistemaPersistenciaServidor: Solo el servidor puede consultar estados")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_estado_chunk_fallido")
            
            return instance.CargarEstadoChunk(coordenada)
        }, "SistemaPersistenciaServidor.ObtenerEstadoChunk", false)
    
    static function ObtenerListaMundos(): List<Mundo>
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_lista_mundos_fallida")
            
            if not SessionData.Instance.es_servidor:
                Logger.LogError("SistemaPersistenciaServidor: Solo el servidor puede listar mundos")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("obtener_lista_mundos_fallida")
            
            return instance.CargarListaMundos()
        }, "SistemaPersistenciaServidor.ObtenerListaMundos", false)
    
    static function ExisteMundo(nombre_mundo: string): bool
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance == null:
                Logger.LogError("SistemaPersistenciaServidor: SessionData no inicializado")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("existe_mundo_fallido")
            
            if not SessionData.Instance.es_servidor:
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("existe_mundo_fallido")
            
            ruta_mundo = Path.Combine(SessionData.Instance.directorio_mundos, nombre_mundo)
            return Directory.Exists(ruta_mundo)
        }, "SistemaPersistenciaServidor.ExisteMundo", false)
    
    # =============================================================================
    # FUNCIONES INTERNAS
    # =============================================================================
    
    function CrearNuevoMundo(nombre_mundo: string, configuracion: ConfiguracionMundo): bool
        return ManejoErrores.EjecutarConManejo(() => {
            ruta_mundo = Path.Combine(SessionData.Instance.directorio_mundos, nombre_mundo)
            
            if Directory.Exists(ruta_mundo):
                Logger.LogError("SistemaPersistenciaServidor: El mundo ya existe: " + nombre_mundo)
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("crear_nuevo_mundo_fallido")
            
            # Crear directorio del mundo
            Directory.CreateDirectory(ruta_mundo)
            
            # Crear metadatos del mundo
            metadatos = new MetadatosMundo()
            metadatos.nombre = nombre_mundo
            metadatos.fecha_creacion = DateTime.Now()
            metadatos.configuracion = configuracion
            metadatos.semilla = GenerarSemilla()
            
            GuardarMetadatosMundo(ruta_mundo, metadatos)
            
            # Crear estructura inicial
            CrearEstructuraMundo(ruta_mundo)
            
            Logger.LogInfo("SistemaPersistenciaServidor: Mundo creado exitosamente: " + nombre_mundo)
            return true
        }, "SistemaPersistenciaServidor.CrearNuevoMundo", false)
    
    function ConectarAMundo(nombre_mundo: string): bool
        return ManejoErrores.EjecutarConManejo(() => {
            ruta_mundo = Path.Combine(SessionData.Instance.directorio_mundos, nombre_mundo)
            
            if not Directory.Exists(ruta_mundo):
                Logger.LogError("SistemaPersistenciaServidor: El mundo no existe: " + nombre_mundo)
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("conectar_a_mundo_fallido")
            
            # Cargar metadatos
            metadatos = CargarMetadatosMundo(ruta_mundo)
            
            # Establecer mundo actual
            SessionData.Instance.mundo_actual = nombre_mundo
            
            # Inicializar persistencia para este mundo
            InicializarPersistenciaMundo(ruta_mundo)
            
            Logger.LogInfo("SistemaPersistenciaServidor: Conectado al mundo: " + nombre_mundo)
            return true
        }, "SistemaPersistenciaServidor.ConectarAMundo", false)
    
    function DesconectarDeMundo():
        return ManejoErrores.EjecutarConManejo(() => {
            if SessionData.Instance.mundo_actual != null:
                # Procesar todas las transacciones pendientes
                ProcesarTodasTransacciones()
                
                SessionData.Instance.mundo_actual = null
                Logger.LogInfo("SistemaPersistenciaServidor: Desconectado del mundo")
            return true
        }, "SistemaPersistenciaServidor.DesconectarDeMundo", false)
    
    function AgregarTransaccion(transaccion: TransaccionPersistencia):
        return ManejoErrores.EjecutarConManejo(() => {
            lock(cola_transacciones):
                cola_transacciones.Enqueue(transaccion)
            return true
        }, "SistemaPersistenciaServidor.AgregarTransaccion", false)
    
    function IniciarHiloPersistencia():
        return ManejoErrores.EjecutarConManejo(() => {
            hilo_persistencia = Thread.Start(function():
                BuclePersistencia()
            end)
            return true
        }, "SistemaPersistenciaServidor.IniciarHiloPersistencia", false)
    
    function BuclePersistencia():
        return ManejoErrores.EjecutarConManejo(() => {
            while SessionData.Instance.ejecutando:
                try:
                    # Procesar transacciones en cola
                    while cola_transacciones.length() > 0:
                        transaccion = null
                        
                        lock(cola_transacciones):
                            if cola_transacciones.length() > 0:
                                transaccion = cola_transacciones.Dequeue()
                        
                        if transaccion != null:
                            ProcesarTransaccion(transaccion)
                    
                    # Pequeña pausa para no sobrecargar CPU
                    Thread.Sleep(1)  # 1ms
                    
                except error:
                    Logger.LogError("SistemaPersistenciaServidor: Error en bucle de persistencia: " + error.message)
            return true
        }, "SistemaPersistenciaServidor.BuclePersistencia", false)
    
    function ProcesarTransaccion(transaccion: TransaccionPersistencia):
        return ManejoErrores.EjecutarConManejo(() => {
            switch transaccion.tipo:
                case TipoTransaccion.JUGADOR:
                    ProcesarTransaccionJugador(transaccion as TransaccionJugador)
                case TipoTransaccion.CHUNK:
                    ProcesarTransaccionChunk(transaccion as TransaccionChunk)
                case TipoTransaccion.ACCION:
                    ProcesarTransaccionAccion(transaccion as TransaccionAccion)
                case TipoTransaccion.TERRENO:
                    ProcesarTransaccionTerreno(transaccion as TransaccionTerreno)
                case TipoTransaccion.INVENTARIO:
                    ProcesarTransaccionInventario(transaccion as TransaccionInventario)
            return true
        }, "SistemaPersistenciaServidor.ProcesarTransaccion", false)
    
    function ProcesarTransaccionJugador(transaccion: TransaccionJugador):
        return ManejoErrores.EjecutarConManejo(() => {
            # Obtener ID del personaje desde el jugador
            id_personaje = transaccion.jugador.id_personaje
            
            if id_personaje == "":
                Logger.LogError("SistemaPersistenciaServidor: Jugador sin ID de personaje")
                return EstadoSeguroPersistencia.ObtenerValorPorDefecto("procesar_jugador_fallido")
            
            # Generar ruta específica para este personaje en este mundo
            ruta_jugador = ObtenerRutaJugador(id_personaje)
            
            # Crear directorio del personaje si no existe
            if not Directory.Exists(ruta_jugador):
                Directory.CreateDirectory(ruta_jugador)
            
            # Serializar datos específicos del mundo
            datos_mundo = ObtenerDatosPersonajeMundo(id_personaje, SessionData.Instance.mundo_actual)
            datos_mundo.vida = transaccion.jugador.vida
            datos_mundo.vida_maxima = transaccion.jugador.vida_maxima
            datos_mundo.hambre = transaccion.jugador.hambre
            datos_mundo.sed = transaccion.jugador.sed
            datos_mundo.posicion = transaccion.jugador.posicion
            datos_mundo.rotacion = transaccion.jugador.rotacion
            datos_mundo.ultima_conexion = DateTime.Now
            
            # Guardar en archivos JSON según estructura
            GuardarDatosPersonajeJson(ruta_jugador, datos_mundo)
            
            # Registrar en mundo.log
            LogMundo("Jugador actualizado: " + id_personaje + " en posición " + transaccion.jugador.posicion.ToString())")
            
            # Registrar en eventos.json
            RegistrarEventoJugador("ACTUALIZACION_JUGADOR", id_personaje, "Datos de personaje guardados", {
                "posicion": transaccion.jugador.posicion.ToString(),
                "vida": transaccion.jugador.vida,
                "hambre": transaccion.jugador.hambre,
                "sed": transaccion.jugador.sed
            })
            
            # Actualizar también datos locales del cliente
            ActualizarDatosPersonajeCliente(id_personaje, datos_mundo)
            return true
        }, "SistemaPersistenciaServidor.ProcesarTransaccionJugador", false)
    
    function ProcesarTransaccionChunk(transaccion: TransaccionChunk):
        return ManejoErrores.EjecutarConManejo(() => {
            ruta_chunk = ObtenerRutaChunk(transaccion.chunk.coordenada)
            
            # Serializar chunk a formato binario .dat
            datos_chunk = SerializarChunkADat(transaccion.chunk)
            
            # Guardar en archivo .dat
            File.WriteAllBytes(ruta_chunk, datos_chunk)
            
            # Registrar en mundo.log
            LogMundo("Chunk actualizado: " + transaccion.chunk.coordenada.AClaveString())
            
            # Registrar en eventos.json
            RegistrarEventoJugador("ACTUALIZACION_CHUNK", "sistema", "Chunk guardado", {
                "coordenada": transaccion.chunk.coordenada.AClaveString(),
                "tamaño": datos_chunk.length()
            })
            return true
        }, "SistemaPersistenciaServidor.ProcesarTransaccionChunk", false)
    
    function ProcesarTransaccionAccion(transaccion: TransaccionAccion):
        return ManejoErrores.EjecutarConManejo(() => {
            # Las acciones se registran en mundo.log y eventos.json
            linea_accion = FormatearAccionParaLog(transaccion.accion)
            LogMundo(linea_accion)
            
            RegistrarEventoJugador("ACCION_JUGADOR", transaccion.accion.id_jugador, "Acción registrada", {
                "tipo_accion": transaccion.accion.tipo_accion.ToString(),
                "timestamp": transaccion.accion.timestamp.ToString("yyyy-MM-ddTHH:mm:ssZ")
            })
            return true
        }, "SistemaPersistenciaServidor.ProcesarTransaccionAccion", false)
    
    function ProcesarTransaccionTerreno(transaccion: TransaccionTerreno):
        return ManejoErrores.EjecutarConManejo(() => {
            # Las modificaciones de terreno se guardan en el chunk correspondiente
            coord_chunk = new CoordenadaChunk(
                transaccion.modificacion.coordenada.chunk_x,
                transaccion.modificacion.coordenada.chunk_z
            )
            
            # Cargar chunk existente si hay
            ruta_chunk = ObtenerRutaChunk(transaccion.modificacion.coordenada)
            chunk_datos = new DatosChunk()
            
            if File.Exists(ruta_chunk):
                chunk_bytes = File.ReadAllBytes(ruta_chunk)
                chunk_datos = DeserializarChunkDesdeDat(chunk_bytes)
            
            # Aplicar modificación
            chunk_datos = AplicarModificacionTerreno(chunk_datos, transaccion.modificacion)
            
            # Guardar chunk actualizado
            chunk_bytes_actualizado = SerializarChunkADat(chunk_datos)
            File.WriteAllBytes(ruta_chunk, chunk_bytes_actualizado)
            
            # Registrar en mundo.log
            LogMundo("Terreno modificado: " + transaccion.modificacion.coordenada.AClaveString())
            
            # Registrar en eventos.json
            RegistrarEventoJugador("MODIFICACION_TERRENO", "sistema", "Terreno modificado", {
                "coordenada": transaccion.modificacion.coordenada.AClaveString(),
                "tipo_modificacion": transaccion.modificacion.tipo_modificacion.ToString()
            })
            return true
        }, "SistemaPersistenciaServidor.ProcesarTransaccionTerreno", false)
    
    function ProcesarTransaccionInventario(transaccion: TransaccionInventario):
        return ManejoErrores.EjecutarConManejo(() => {
            # El inventario se guarda junto con los datos del jugador
            # Esta transacción se procesa junto con la del jugador
            return EstadoSeguroPersistencia.ObtenerValorPorDefecto("procesar_inventario_fallido")
        }, "SistemaPersistenciaServidor.ProcesarTransaccionInventario", false)
    
    # =============================================================================
    # FUNCIONES DE UTILIDAD
    # =============================================================================
    
    function CrearDirectorioMundos():
        return ManejoErrores.EjecutarConManejo(() => {
            if not Directory.Exists(SessionData.Instance.directorio_mundos):
                Directory.CreateDirectory(SessionData.Instance.directorio_mundos)
            return true
        }, "SistemaPersistenciaServidor.CrearDirectorioMundos", false)
    
    function CrearEstructuraMundo(ruta_mundo: string):
        return ManejoErrores.EjecutarConManejo(() => {
            # Crear subdirectorios para archivos .dat
            Directory.CreateDirectory(Path.Combine(ruta_mundo, "chunks"))
            Directory.CreateDirectory(Path.Combine(ruta_mundo, "personajes"))
            Directory.CreateDirectory(Path.Combine(ruta_mundo, "logs"))
            
            # Crear seed.txt
            seed_txt = Path.Combine(ruta_mundo, "seed.txt")
            File.WriteAllText(seed_txt, metadatos.semilla.ToString())
            
            # Crear metadata.json
            metadata_json = Path.Combine(ruta_mundo, "metadata.json")
            metadata_content = {
                "seed": metadatos.semilla,
                "nombre": metadatos.nombre,
                "fecha_creacion": metadatos.fecha_creacion.ToString("yyyy-MM-ddTHH:mm:ssZ"),
                "ultimo_acceso": DateTime.Now().ToString("yyyy-MM-ddTHH:mm:ssZ"),
                "version": "2.0.0",
                "estadisticas": {
                    "chunks_generados": 0,
                    "jugadores_visitantes": 0,
                    "horas_jugadas": 0.0,
                    "fecha_ultimo_guardado": DateTime.Now().ToString("yyyy-MM-ddTHH:mm:ssZ")
                },
                "configuracion": {
                    "calidad_render": "Medium",
                    "distancia_render": 1000,
                    "tiempo_dia": 12.5,
                    "clima_actual": "Despejado"
                }
            }
            File.WriteAllText(metadata_json, JsonConvert.SerializeObject(metadata_content, Formatting.Indented))
            
            # Crear mundo.log
            mundo_log = Path.Combine(ruta_mundo, "logs", "mundo.log")
            File.WriteAllText(mundo_log, "# Mundo log for " + metadatos.nombre + "\n")
            
            # Crear eventos.json
            eventos_json = Path.Combine(ruta_mundo, "logs", "eventos.json")
            File.WriteAllText(eventos_json, "{\"eventos_recientes\": []}")
            return true
        }, "SistemaPersistenciaServidor.CrearEstructuraMundo", false)
    
    function ObtenerRutaJugador(id_jugador_md5: string): string
        return ManejoErrores.EjecutarConManejo(() => {
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "personajes", id_jugador_md5)
        }, "SistemaPersistenciaServidor.ObtenerRutaJugador", false)
    
    function ObtenerRutaChunk(coordenada: CoordenadaGlobal): string
        return ManejoErrores.EjecutarConManejo(() => {
            # Formato: chunk_x_chunk_z.dat
            clave = coordenada.chunk_x.ToString() + "_" + coordenada.chunk_z.ToString()
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "chunks", clave + ".dat")
        }, "SistemaPersistenciaServidor.ObtenerRutaChunk", false)
    
    function ObtenerRutaMundoLog(): string
        return ManejoErrores.EjecutarConManejo(() => {
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "logs", "mundo.log")
        }, "SistemaPersistenciaServidor.ObtenerRutaMundoLog", false)
    
    function ObtenerRutaEventosJson(): string
        return ManejoErrores.EjecutarConManejo(() => {
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "logs", "eventos.json")
        }, "SistemaPersistenciaServidor.ObtenerRutaEventosJson", false)
    
    function ObtenerRutaSeedTxt(): string
        return ManejoErrores.EjecutarConManejo(() => {
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "seed.txt")
        }, "SistemaPersistenciaServidor.ObtenerRutaSeedTxt", false)
    
    function ObtenerRutaMetadataJson(): string
        return ManejoErrores.EjecutarConManejo(() => {
            return Path.Combine(SessionData.Instance.directorio_mundos, SessionData.Instance.mundo_actual, "metadata.json")
        }, "SistemaPersistenciaServidor.ObtenerRutaMetadataJson", false)
    
    function ProcesarTodasTransacciones():
        return ManejoErrores.EjecutarConManejo(() => {
            while cola_transacciones.length() > 0:
                Thread.Sleep(10)  # Esperar a que se procesen
            return true
        }, "SistemaPersistenciaServidor.ProcesarTodasTransacciones", false)
    
    function GenerarSemilla(): int
        return ManejoErrores.EjecutarConManejo(() => {
            return Random.Range(0, 2147483647)
        }, "SistemaPersistenciaServidor.GenerarSemilla", false)

# =============================================================================
# CLASES DE TRANSACCIONES
# =============================================================================

class TransaccionPersistencia:
    id: string
    tipo: TipoTransaccion
    timestamp: DateTime
    
    function Constructor(tipo: TipoTransaccion):
        self.id = Guid.NewGuid().ToString()
        self.tipo = tipo
        self.timestamp = DateTime.Now()

class TransaccionJugador extends TransaccionPersistencia:
    jugador: JugadorLocal
    
    function Constructor(jugador: JugadorLocal):
        super.Constructor(TipoTransaccion.JUGADOR)
        self.jugador = jugador

class TransaccionChunk extends TransaccionPersistencia:
    chunk: Chunk
    
    function Constructor(chunk: Chunk):
        super.Constructor(TipoTransaccion.CHUNK)
        self.chunk = chunk

class TransaccionAccion extends TransaccionPersistencia:
    accion: AccionJugador
    
    function Constructor(accion: AccionJugador):
        super.Constructor(TipoTransaccion.ACCION)
        self.accion = accion

class TransaccionTerreno extends TransaccionPersistencia:
    modificacion: ModificacionTerreno
    
    function Constructor(modificacion: ModificacionTerreno):
        super.Constructor(TipoTransaccion.TERRENO)
        self.modificacion = modificacion

class TransaccionInventario extends TransaccionPersistencia:
    inventario: Inventario
    
    function Constructor(inventario: Inventario):
        super.Constructor(TipoTransaccion.INVENTARIO)
        self.inventario = inventario

