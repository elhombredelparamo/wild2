# =============================================================================
# ENUMS
# =============================================================================

class TipoTransaccion:
    static JUGADOR = 0
    static CHUNK = 1
    static ACCION = 2
    static TERRENO = 3
    static INVENTARIO = 4

class ModoJuego:
    static SUPERVIVENCIA = 0
    static CREATIVO = 1
    static AVENTURA = 2
    static ESPECTADOR = 3

class TipoAccion:
    static MOVIMIENTO = 0
    static INTERACCION = 1
    static CONSTRUCCION = 2
    static DESTRUCCION = 3
    static COMBATE = 4

class TipoModificacion:
    static ALTITUD = 0
    static BIOMA = 1
    static VEGETACION = 2
    static RECURSO = 3
    static ESTRUCTURA = 4

function ObtenerDatosPersonajeMundo(id_personaje: string, nombre_mundo: string): DatosPersonajeMundo
        ruta_jugador = ObtenerRutaJugador(id_personaje)
        
        # Verificar si existe el directorio del personaje
        if not Directory.Exists(ruta_jugador):
            # Crear datos por defecto para nuevo personaje en este mundo
            return CrearDatosPersonajePorDefecto(id_personaje, nombre_mundo)
        
        # Intentar cargar datos_mundo.json
        ruta_datos = Path.Combine(ruta_jugador, "datos_mundo.json")
        if File.Exists(ruta_datos):
            datos_json = File.ReadAllText(ruta_datos)
            return JsonConvert.DeserializeObject<DatosPersonajeMundo>(datos_json)
        else:
            # Crear datos por defecto si no existe
            return CrearDatosPersonajePorDefecto(id_personaje, nombre_mundo)
    
    function CrearDatosPersonajePorDefecto(id_personaje: string, nombre_mundo: string): DatosPersonajeMundo
        datos_mundo = new DatosPersonajeMundo()
        datos_mundo.id_personaje = id_personaje
        datos_mundo.nombre_mundo = nombre_mundo
        datos_mundo.fecha_primera_vez = DateTime.Now()
        datos_mundo.ultima_conexion = DateTime.Now
        datos_mundo.vida = 100.0
        datos_mundo.vida_maxima = 100.0
        datos_mundo.hambre = 100.0
        datos_mundo.sed = 100.0
        datos_mundo.posicion = Vector3(0, 10, 0)
        datos_mundo.rotacion = Vector3.ZERO
        datos_mundo.nivel = 1
        datos_mundo.experiencia = 0
        datos_mundo.habilidades = new Dictionary()
        
        # Guardar datos por defecto
        ruta_jugador = ObtenerRutaJugador(id_personaje)
        if not Directory.Exists(ruta_jugador):
            Directory.CreateDirectory(ruta_jugador)
        GuardarDatosPersonajeJson(ruta_jugador, datos_mundo)
        
        return datos_mundo
    
    function GuardarDatosPersonajeJson(ruta_jugador: string, datos: DatosPersonajeMundo):
        # Guardar datos_mundo.json
        ruta_datos = Path.Combine(ruta_jugador, "datos_mundo.json")
        datos_json = JsonConvert.SerializeObject(datos, Formatting.Indented)
        File.WriteAllText(ruta_datos, datos_json)
        
        # Guardar inventario.json
        ruta_inventario = Path.Combine(ruta_jugador, "inventario.json")
        inventario_json = JsonConvert.SerializeObject(datos.inventario, Formatting.Indented)
        File.WriteAllText(ruta_inventario, inventario_json)
        
        # Guardar equipamiento.json
        ruta_equipamiento = Path.Combine(ruta_jugador, "equipamiento.json")
        equipamiento_json = JsonConvert.SerializeObject(datos.equipamiento, Formatting.Indented)
        File.WriteAllText(ruta_equipamiento, equipamiento_json)
    
    function ActualizarDatosPersonajeCliente(id_personaje: string, datos_mundo: DatosPersonajeMundo):
        # Actualizar datos locales del cliente si está disponible
        gestor_personajes = GetGestorPersonajes()
        if gestor_personajes != null:
            gestor_personajes.ActualizarDatosPersonajeMundo(id_personaje, mundo_actual, datos_mundo)
    
    function ObtenerListaPersonajesMundo(nombre_mundo: string): List<string>
        personajes = new List()
        ruta_personajes = Path.Combine(directorio_mundos, nombre_mundo, "personajes")
        
        if Directory.Exists(ruta_personajes):
            directorios = Directory.GetDirectories(ruta_personajes)
            for directorio in directorios:
                nombre_directorio = Path.GetFileName(directorio)
                personajes.Add(nombre_directorio)
        
        return personajes
    
    function EliminarDatosPersonajeMundo(id_personaje: string, nombre_mundo: string): bool
        try:
            ruta_jugador = Path.Combine(directorio_mundos, nombre_mundo, "personajes", id_personaje)
            if Directory.Exists(ruta_jugador):
                Directory.Delete(ruta_jugador, true)
                LogInfo("Datos de personaje eliminados: " + id_personaje + " en mundo " + nombre_mundo)
                return true
        catch error:
            LogError("Error eliminando datos de personaje: " + error.message)
        
        return false

function GenerarMD5(texto: string): string
    return MD5.Hash(texto)

function SerializarDatosPersonajeMundo(datos: DatosPersonajeMundo): byte[]
    writer = new BinaryWriter()
    
    # Metadatos
    writer.Write(datos.id_personaje)
    writer.Write(datos.nombre_mundo)
    writer.Write(datos.fecha_primera_vez.ToBinary())
    writer.Write(datos.ultima_conexion.ToBinary())
    writer.Write(datos.tiempo_jugado.Ticks)
    
    # Estadísticas
    writer.Write(datos.vida)
    writer.Write(datos.vida_maxima)
    writer.Write(datos.hambre)
    writer.Write(datos.sed)
    
    # Posición
    writer.Write(datos.posicion.x)
    writer.Write(datos.posicion.y)
    writer.Write(datos.posicion.z)
    writer.Write(datos.rotacion.x)
    writer.Write(datos.rotacion.y)
    writer.Write(datos.rotacion.z)
    
    # Progreso
    writer.Write(datos.nivel)
    writer.Write(datos.experiencia)
    
    # Serializar inventario
    inventario_bytes = SerializarInventarioADat(datos.inventario)
    writer.Write(inventario_bytes.length())
    writer.Write(inventario_bytes)
    
    # Serializar equipamiento
    writer.Write(datos.equipamiento.length())
    for slot, item in datos.equipamiento:
        writer.Write((int)slot)
        item_bytes = SerializarItemADat(item)
        writer.Write(item_bytes.length())
        writer.Write(item_bytes)
    
    # Serializar habilidades
    writer.Write(datos.habilidades.length())
    for habilidad, nivel in datos.habilidades:
        writer.Write(habilidad)
        writer.Write(nivel)
    
    return writer.ToArray()

function DeserializarDatosPersonajeMundo(datos: byte[]): DatosPersonajeMundo
    reader = new BinaryReader(datos)
    datos_mundo = new DatosPersonajeMundo()
    
    # Metadatos
    datos_mundo.id_personaje = reader.ReadString()
    datos_mundo.nombre_mundo = reader.ReadString()
    datos_mundo.fecha_primera_vez = DateTime.FromBinary(reader.ReadInt64())
    datos_mundo.ultima_conexion = DateTime.FromBinary(reader.ReadInt64())
    datos_mundo.tiempo_jugado = TimeSpan.FromTicks(reader.ReadInt64())
    
    # Estadísticas
    datos_mundo.vida = reader.ReadSingle()
    datos_mundo.vida_maxima = reader.ReadSingle()
    datos_mundo.hambre = reader.ReadSingle()
    datos_mundo.sed = reader.ReadSingle()
    
    # Posición
    datos_mundo.posicion = Vector3(reader.ReadSingle(), reader.ReadSingle(), reader.ReadSingle())
    datos_mundo.rotacion = Vector3(reader.ReadSingle(), reader.ReadSingle(), reader.ReadSingle())
    
    # Progreso
    datos_mundo.nivel = reader.ReadInt32()
    datos_mundo.experiencia = reader.ReadInt64()
    
    # Deserializar inventario
    inventario_size = reader.ReadInt32()
    inventario_bytes = reader.ReadBytes(inventario_size)
    datos_mundo.inventario = DeserializarInventarioDesdeDat(inventario_bytes)
    
    # Deserializar equipamiento
    equipamiento_count = reader.ReadInt32()
    datos_mundo.equipamiento = new Dictionary()
    for i in 0..equipamiento_count-1:
        slot = (EquipmentSlot)reader.ReadInt32()
        item_size = reader.ReadInt32()
        item_bytes = reader.ReadBytes(item_size)
        datos_mundo.equipamiento[slot] = DeserializarItemDesdeDat(item_bytes)
    
    # Deserializar habilidades
    habilidades_count = reader.ReadInt32()
    datos_mundo.habilidades = new Dictionary()
    for i in 0..habilidades_count-1:
        habilidad = reader.ReadString()
        nivel = reader.ReadInt32()
        datos_mundo.habilidades[habilidad] = nivel
    
    return datos_mundo

function SerializarItemADat(item: ItemData): byte[]
    writer = new BinaryWriter()
    writer.Write(item.id)
    writer.Write(item.nombre)
    writer.Write((int)item.tipo)
    writer.Write(item.cantidad)
    writer.Write(item.peso)
    writer.Write(item.durabilidad)
    return writer.ToArray()

function DeserializarItemDesdeDat(datos: byte[]): ItemData
    reader = new BinaryReader(datos)
    item = new ItemData()
    item.id = reader.ReadString()
    item.nombre = reader.ReadString()
    item.tipo = (ItemType)reader.ReadInt32()
    item.cantidad = reader.ReadInt32()
    item.peso = reader.ReadSingle()
    item.durabilidad = reader.ReadSingle()
    return item

function SerializarInventarioADat(inventario: CharacterInventory): byte[]
    writer = new BinaryWriter()
    
    # Items en inventario
    writer.Write(inventario.items.length())
    for item in inventario.items:
        item_bytes = SerializarItemADat(item)
        writer.Write(item_bytes.length())
        writer.Write(item_bytes)
    
    # Items equipados
    writer.Write(inventario.equipped_items.length())
    for slot, item in inventario.equipped_items:
        writer.Write((int)slot)
        item_bytes = SerializarItemADat(item)
        writer.Write(item_bytes.length())
        writer.Write(item_bytes)
    
    # Propiedades
    writer.Write(inventario.max_weight)
    writer.Write(inventario.max_slots)
    
    return writer.ToArray()

function DeserializarInventarioDesdeDat(datos: byte[]): CharacterInventory
    reader = new BinaryReader(datos)
    inventario = new CharacterInventory()
    
    # Items en inventario
    items_count = reader.ReadInt32()
    inventario.items = new List()
    for i in 0..items_count-1:
        item_size = reader.ReadInt32()
        item_bytes = reader.ReadBytes(item_size)
        inventario.items.Add(DeserializarItemDesdeDat(item_bytes))
    
    # Items equipados
    equipped_count = reader.ReadInt32()
    inventario.equipped_items = new Dictionary()
    for i in 0..equipped_count-1:
        slot = (EquipmentSlot)reader.ReadInt32()
        item_size = reader.ReadInt32()
        item_bytes = reader.ReadBytes(item_size)
        inventario.equipped_items[slot] = DeserializarItemDesdeDat(item_bytes)
    
    # Propiedades
    inventario.max_weight = reader.ReadSingle()
    inventario.max_slots = reader.ReadInt32()
    
    return inventario

function SerializarChunkADat(chunk: Chunk): byte[]
    writer = new BinaryWriter()
    writer.Write(chunk.coordenada.chunk_x)
    writer.Write(chunk.coordenada.chunk_z)
    
    # Serializar alturas 10x10
    for x in 0..9:
        for z in 0..9:
            writer.Write(chunk.datos.altitudes[x, z])
    
    # Serializar tipo de terreno
    for x in 0..9:
        for z in 0..9:
            writer.Write(chunk.datos.tipo_terreno[x, z])
    
    # Serializar vegetación
    writer.Write(chunk.datos.vegetacion.length())
    for vegetacion in chunk.datos.vegetacion:
        writer.Write(vegetacion.tipo)
        writer.Write(vegetacion.posicion.x)
        writer.Write(vegetacion.posicion.y)
        writer.Write(vegetacion.posicion.z)
    
    return writer.ToArray()

function SerializarWorldDat(metadatos: MetadatosMundo): byte[]
    writer = new BinaryWriter()
    writer.Write(metadatos.nombre)
    writer.Write(metadatos.fecha_creacion.ToBinary())
    writer.Write(metadatos.semilla)
    writer.Write(metadatos.version_juego)
    return writer.ToArray()

function DeserializarChunkDesdeDat(datos: byte[]): DatosChunk
    reader = new BinaryReader(datos)
    chunk_datos = new DatosChunk()
    
    chunk_datos.chunk_x = reader.ReadInt32()
    chunk_datos.chunk_z = reader.ReadInt32()
    
    # Leer altitudes 10x10
    for x in 0..9:
        for z in 0..9:
            chunk_datos.altitudes[x, z] = reader.ReadSingle()
    
    # Leer tipo de terreno
    for x in 0..9:
        for z in 0..9:
            chunk_datos.tipo_terreno[x, z] = reader.ReadInt32()
    
    return chunk_datos

function LogMundo(mensaje: string):
    return ManejoErrores.EjecutarConManejo(() => {
        ruta_log = ObtenerRutaMundoLog()
        timestamp = DateTime.Now().ToString("yyyy-MM-dd HH:mm:ss")
        linea = timestamp + " [INFO] " + mensaje
        File.AppendAllText(ruta_log, linea + "\n")
        Logger.LogInfo("SistemaPersistenciaServidor: " + mensaje)
    }, "LogMundo", false)

function LogErrorMundo(mensaje: string):
    return ManejoErrores.EjecutarConManejo(() => {
        ruta_log = ObtenerRutaMundoLog()
        timestamp = DateTime.Now().ToString("yyyy-MM-dd HH:mm:ss")
        linea = timestamp + " [ERROR] " + mensaje
        File.AppendAllText(ruta_log, linea + "\n")
        Logger.LogError("SistemaPersistenciaServidor: " + mensaje)
    }, "LogErrorMundo", false)

function RegistrarEventoJugador(tipo: string, jugador: string, descripcion: string, detalles: object):
    return ManejoErrores.EjecutarConManejo(() => {
        ruta_eventos = ObtenerRutaEventosJson()
        
        # Cargar eventos existentes
        eventos_actuales = []
        if File.Exists(ruta_eventos):
            eventos_json = File.ReadAllText(ruta_eventos)
            eventos_actuales = JsonConvert.DeserializeObject(eventos_json)["eventos_recientes"]
        
        # Crear nuevo evento
        nuevo_evento = {
            "timestamp": DateTime.Now().ToString("yyyy-MM-ddTHH:mm:ssZ"),
            "tipo": tipo,
            "jugador": jugador,
            "descripcion": descripcion,
            "detalles": detalles
        }
        
        # Agregar a la lista (máximo 100 eventos recientes)
        eventos_actuales.Insert(0, nuevo_evento)
        if eventos_actuales.length() > 100:
            eventos_actuales.RemoveAt(eventos_actuales.length() - 1)
        
        # Guardar eventos actualizados
        eventos_completos = {
            "eventos_recientes": eventos_actuales
        }
        File.WriteAllText(ruta_eventos, JsonConvert.SerializeObject(eventos_completos, Formatting.Indented))
        Logger.LogInfo("SistemaPersistenciaServidor: Evento registrado: " + tipo + " - " + descripcion)
    }, "RegistrarEventoJugador", false)

function FormatearAccionParaLog(accion: AccionJugador): string
    return ManejoErrores.EjecutarConManejo(() => {
        timestamp = accion.timestamp.ToString("yyyy-MM-dd HH:mm:ss")
        return timestamp + " [ACTION] " + accion.id_jugador + ": " + accion.tipo_accion.ToString()
    }, "FormatearAccionParaLog", false)

function SerializarInventarioADat(inventario: Inventario): byte[]
    # Implementar serialización de inventario
    pass

function AplicarModificacionTerreno(chunk_datos: DatosChunk, modificacion: ModificacionTerreno): DatosChunk
    # Aplicar modificación al chunk
    return chunk_datos

# =============================================================================
# FUNCIONES GLOBALES DE ACCESO RÁPIDO
# =============================================================================
function CrearMundo(nombre: string, seed: int, descripcion: string): Resultado
    return ManejoErrores.EjecutarConManejo(() => {
        config = new ConfiguracionMundo()
        config.nombre = nombre
        config.modo_juego = ModoJuego.SUPERVIVENCIA
        config.dificultad = Dificultad.NORMAL
        config.pvp = false
        config.max_jugadores = 32
        
        exito = SistemaPersistenciaServidor.CrearMundo(nombre, config)
        if exito:
            Logger.LogInfo("SistemaPersistenciaServidor: Mundo creado exitosamente: " + nombre)
            return new Resultado(true)
        else:
            Logger.LogError("SistemaPersistenciaServidor: Error creando mundo: " + nombre)
            return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
    }, "CrearMundo", false)

function ConectarMundo(nombre: string): Resultado
    return ManejoErrores.EjecutarConManejo(() => {
        exito = SistemaPersistenciaServidor.ConectarMundo(nombre)
        if exito:
            Logger.LogInfo("SistemaPersistenciaServidor: Conectado exitosamente: " + nombre)
            return new Resultado(true)
        else:
            Logger.LogError("SistemaPersistenciaServidor: Error conectando: " + nombre)
            return EstadoSeguroPersistencia.ObtenerValorPorDefecto("resultado_fallido")
    }, "ConectarMundo", false)

function DesconectarMundo():
    return ManejoErrores.EjecutarConManejo(() => {
        SistemaPersistenciaServidor.DesconectarMundo()
        Logger.LogInfo("SistemaPersistenciaServidor: Desconectado del mundo")
        return true
    }, "DesconectarMundo", false)

function PersistirJugador(jugador: JugadorLocal):
    return ManejoErrores.EjecutarConManejo(() => {
        SistemaPersistenciaServidor.PersistirJugador(jugador)
        return true
    }, "PersistirJugador", false)

function PersistirChunk(chunk: Chunk):
    return ManejoErrores.EjecutarConManejo(() => {
        SistemaPersistenciaServidor.PersistirChunk(chunk)
        return true
    }, "PersistirChunk", false)

function GetMundoActual(): string
    return ManejoErrores.EjecutarConManejo(() => {
        if SessionData.Instance != null:
            return SessionData.Instance.mundo_actual
        else:
            return EstadoSeguroPersistencia.ObtenerValorPorDefecto("mundo_actual")
    }, "GetMundoActual", false)

function EstaConectadoMundo(): bool
    return ManejoErrores.EjecutarConManejo(() => {
        if SessionData.Instance != null:
            return SessionData.Instance.mundo_actual != null
        else:
            return EstadoSeguroPersistencia.ObtenerValorPorDefecto("existe_mundo_fallido")
    }, "EstaConectadoMundo", false)

function GetMundosDisponibles(): List<Mundo>
    return ManejoErrores.EjecutarConManejo(() => {
        return SistemaPersistenciaServidor.ObtenerListaMundos()
    }, "GetMundosDisponibles", false)

# =============================================================================
# CLASES DE DATOS ADICIONALES
# =============================================================================
class DatosChunk:
    chunk_x: int
    chunk_z: int
    altitudes: float[10, 10]
    tipo_terreno: int[10, 10]
    vegetacion: List<ElementoVegetacion>

class ElementoVegetacion:
    tipo: int
    posicion: Vector3

class DatosPersonajeMundo:
    id_personaje: string
    nombre_mundo: string
    fecha_primera_vez: DateTime
    ultima_conexion: DateTime
    tiempo_jugado: TimeSpan
    vida: float
    vida_maxima: float
    hambre: float
    sed: float
    posicion: Vector3
    rotacion: Vector3
    nivel: int
    experiencia: long
    inventario: Inventario
    equipamiento: Dictionary<EquipmentSlot, ItemData>
    habilidades: Dictionary<string, int>

class Resultado:
    exito: bool
    error: string
    
    function Constructor(exito: bool, error: string = ""):
        self.exito = exito
        self.error = error

class Mundo:
    nombre: string
    seed: int
    fecha_creacion: DateTime
    ultimo_acceso: DateTime
