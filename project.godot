; Engine configuration file.
; Godot 4 - Videojuego 3D Simulación Realista (Wild)
; Lenguaje: C#

config_version=5

[application]

config/name="Wild"
config/description="Videojuego 3D de simulación realista con generación procedural."
config/version="0.2.0-alpha"
run/main_scene="res://scenes/splash_screen.tscn"
config/features=PackedStringArray("4.3", "C#")

[physics]

common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
[autoload]

GameFlow="*res://scripts/autoload/GameFlow.cs"
SessionData="*res://scripts/autoload/SessionData.cs"
GameSettings="*res://scripts/autoload/GameSettings.cs"
WorldManager="*res://scripts/WorldManager.cs"
CharacterManager="*res://scripts/character/CharacterManager.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="Wild"

